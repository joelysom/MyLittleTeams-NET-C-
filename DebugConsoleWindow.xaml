<mah:MetroWindow x:Class="MeuApp.DebugConsoleWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:MeuApp"
                 xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                 mc:Ignorable="d"
                 Title="Obsseract Debug Console"
                 Width="540"
                 Height="820"
                 MinWidth="420"
                 MinHeight="420"
                 ShowInTaskbar="False"
                 ShowActivated="False"
                 ResizeMode="CanResize"
                 WindowStartupLocation="Manual"
                 Background="#07111F"
                 GlowBrush="#38BDF8">
    <mah:MetroWindow.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="#132238"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#22344B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ToolbarToggleStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="#132238"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#22344B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#0F766E"/>
                    <Setter Property="BorderBrush" Value="#14B8A6"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Background="#07111F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="14,14,14,10"
                Padding="16"
                CornerRadius="18"
                Background="#0F172A"
                BorderBrush="#1E293B"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Mini console de runtime"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#E2E8F0"/>
                    <TextBlock Text="Eventos do Firebase, sincronização, UI, carregamentos e erros aparecem aqui em tempo real."
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="#94A3B8"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#082F49"
                        BorderBrush="#0EA5E9"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="10,5"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="ModeBadgeText"
                               Text="AO VIVO"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#BAE6FD"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="14,0,14,10"
                Padding="14"
                CornerRadius="16"
                Background="#0B1220"
                BorderBrush="#1E293B"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Margin="12,0,0,0">
                    <ToggleButton x:Name="PauseToggleButton"
                                  Style="{StaticResource ToolbarToggleStyle}"
                                  Content="Pausar"
                                  Checked="PauseToggleButton_Changed"
                                  Unchecked="PauseToggleButton_Changed"/>
                    <ToggleButton x:Name="AutoScrollToggleButton"
                                  Style="{StaticResource ToolbarToggleStyle}"
                                  Content="Auto-scroll"
                                  IsChecked="True"
                                  Checked="AutoScrollToggleButton_Changed"
                                  Unchecked="AutoScrollToggleButton_Changed"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="Limpar"
                            Click="ClearButton_Click"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="Copiar"
                            Click="CopyButton_Click"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="Abrir log"
                            Click="OpenLogButton_Click"/>
                </StackPanel>

                <TextBox x:Name="FilterTextBox"
                         Height="40"
                         Padding="12,8"
                         Background="#132238"
                         Foreground="#E2E8F0"
                         BorderBrush="#22344B"
                         BorderThickness="1"
                         CaretBrush="#E2E8F0"
                         TextChanged="FilterTextBox_TextChanged"
                         ToolTip="Filtre por texto, endpoint, método, status ou prefixo de log."/>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="14,0,14,10"
                Padding="12"
                CornerRadius="18"
                Background="#020617"
                BorderBrush="#1E293B"
                BorderThickness="1">
            <ListBox x:Name="LogListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:DebugConsoleEntryViewModel}">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding TimestampLabel}"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="11"
                                       Foreground="#7DD3FC"
                                       VerticalAlignment="Top"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Message}"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="12"
                                       Foreground="{Binding Foreground}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="3"
                Margin="14,0,14,14"
                Padding="14"
                CornerRadius="16"
                Background="#0B1220"
                BorderBrush="#1E293B"
                BorderThickness="1">
            <StackPanel>
                <WrapPanel>
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Aguardando logs..."
                               FontSize="12"
                               Foreground="#CBD5E1"
                               Margin="0,0,14,4"/>
                    <TextBlock x:Name="CountTextBlock"
                               Text="0 linhas"
                               FontSize="12"
                               Foreground="#94A3B8"
                               Margin="0,0,14,4"/>
                    <TextBlock x:Name="HostWindowTextBlock"
                               Text="Sem janela associada"
                               FontSize="12"
                               Foreground="#94A3B8"
                               Margin="0,0,0,4"/>
                </WrapPanel>
                <TextBlock x:Name="LogPathTextBlock"
                           Margin="0,4,0,0"
                           FontSize="11"
                           Foreground="#64748B"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</mah:MetroWindow>