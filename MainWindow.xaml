<Window x:Class="MeuAppWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teams Modern" Height="720" Width="1280"
        WindowState="Maximized"
        Background="#FFFFFF">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue">#0078D4</SolidColorBrush>
        <SolidColorBrush x:Key="DarkBlue">#004578</SolidColorBrush>
        <SolidColorBrush x:Key="LightGray">#F3F3F3</SolidColorBrush>
        <SolidColorBrush x:Key="DarkGray">#616161</SolidColorBrush>
        <SolidColorBrush x:Key="White">#FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="BorderGray">#E1E1E1</SolidColorBrush>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#616161"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E7E7E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="{StaticResource White}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DarkBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource White}" BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,1,0">
            <StackPanel Orientation="Vertical">
                <!-- Header Sidebar -->
                <Border Background="{StaticResource PrimaryBlue}" Padding="16,16">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="MyApp" FontSize="20" FontWeight="Bold" Foreground="{StaticResource White}" Margin="0,0,0,4"/>
                        <TextBlock Text="Chat e Colaboracao" FontSize="11" Foreground="{StaticResource White}" Opacity="0.9"/>
                    </StackPanel>
                </Border>

                <Separator Background="{StaticResource BorderGray}" Height="1" Margin="0"/>

                <!-- Botoes Navegacao -->
                <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                    <Button Content="Chats" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="Chats"/>
                    <Button Content="Equipes" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="Equipes"/>
                    <Button Content="Calendario" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="Calendario"/>
                    <Button Content="Arquivos" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="Arquivos"/>
                    <Button Content="Configuracoes" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" Tag="Configuracoes"/>
                </StackPanel>

                <Separator Background="{StaticResource BorderGray}" Height="1" Margin="0,16,0,0"/>

                <!-- Conversas Recentes -->
                <TextBlock Text="RECENTES" FontSize="11" FontWeight="Bold" Foreground="{StaticResource DarkGray}" Margin="16,16,16,8"/>
                
                <StackPanel Orientation="Vertical" Margin="8,0,8,0">
                    <Border Background="{StaticResource LightGray}" Padding="12,10" Margin="0,4" CornerRadius="4">
                        <TextBlock Text="Joao Silva" FontSize="13"/>
                    </Border>
                    <Border Background="{StaticResource LightGray}" Padding="12,10" Margin="0,4" CornerRadius="4">
                        <TextBlock Text="Maria Santos" FontSize="13"/>
                    </Border>
                    <Border Background="{StaticResource LightGray}" Padding="12,10" Margin="0,4" CornerRadius="4">
                        <TextBlock Text="Equipe Dev" FontSize="13"/>
                    </Border>
                </StackPanel>

                <!-- Profile -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Height="80">
                    <Separator Background="{StaticResource BorderGray}" Height="1" Margin="0"/>
                    <Border Padding="12,12" Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" Background="{StaticResource PrimaryBlue}" CornerRadius="20">
                                <TextBlock Text="U" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Seu Nome" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="Online" FontSize="11" Foreground="{StaticResource DarkGray}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- CONTEUDO PRINCIPAL -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER TOP BAR -->
            <Border Grid.Row="0" Background="{StaticResource White}" BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Bem-vindo ao Chat" FontSize="18" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>

                    <!-- Botoes Header -->
                    <Button Grid.Column="1" Content="Pesquisar" Foreground="{StaticResource DarkGray}" Background="Transparent" 
                            BorderThickness="0" Margin="0,0,12,0" Padding="12,8" FontSize="12" Cursor="Hand"/>
                    <Button Grid.Column="2" Content="Notificacoes" Foreground="{StaticResource DarkGray}" Background="Transparent" 
                            BorderThickness="0" Margin="0,0,12,0" Padding="12,8" FontSize="12" Cursor="Hand"/>
                    <Button Grid.Column="3" Content="Menu" Foreground="{StaticResource DarkGray}" Background="Transparent" 
                            BorderThickness="0" Padding="12,8" FontSize="12" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- AREAS CONTEUDO -->
            <Grid Grid.Row="1">
                <!-- Conteudo Chats -->
                <StackPanel x:Name="ChatsContent" Orientation="Vertical" Margin="24,24">
                    <TextBlock Text="Conversas Ativas" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    
                    <Border Background="{StaticResource LightGray}" Padding="16" CornerRadius="8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Joao Silva" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Ultima mensagem: Otimo! Vamos nos encontrar amanha..." FontSize="12" Foreground="{StaticResource DarkGray}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource LightGray}" Padding="16" CornerRadius="8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Maria Santos" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Ultima mensagem: Recebi o documento, obrigada!" FontSize="12" Foreground="{StaticResource DarkGray}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                        <Button Content="Nova Conversa" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,12,0" Click="Button_Click"/>
                        <Button Content="Iniciar Chamada" Background="{StaticResource LightGray}" Foreground="{StaticResource DarkGray}" BorderThickness="1" BorderBrush="{StaticResource BorderGray}" Padding="20,10" FontSize="12" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>

                <!-- Conteudo Equipes -->
                <StackPanel x:Name="TeamsContent" Orientation="Vertical" Margin="24,24" Visibility="Collapsed">
                    <TextBlock Text="Minhas Equipes" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    
                    <Border Background="{StaticResource LightGray}" Padding="16" CornerRadius="8" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="50" Height="50" Background="{StaticResource PrimaryBlue}" CornerRadius="4">
                                <TextBlock Text="D" FontSize="24" FontWeight="Bold" Foreground="{StaticResource White}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Equipe Desenvolvimento" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="8 membros - 24 canais" FontSize="12" Foreground="{StaticResource DarkGray}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Button Content="Criar Equipe" Style="{StaticResource PrimaryButtonStyle}" Width="150" HorizontalAlignment="Left" Margin="0,24,0,0"/>
                </StackPanel>

                <!-- Conteudo Calendario -->
                <StackPanel x:Name="CalendarContent" Orientation="Vertical" Margin="24,24" Visibility="Collapsed">
                    <TextBlock Text="Calendario" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="Nenhum evento agendado para hoje" FontSize="14" Foreground="{StaticResource DarkGray}"/>
                </StackPanel>

                <!-- Conteudo Arquivos -->
                <StackPanel x:Name="FilesContent" Orientation="Vertical" Margin="24,24" Visibility="Collapsed">
                    <TextBlock Text="Arquivos" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="Nenhum arquivo compartilhado recentemente" FontSize="14" Foreground="{StaticResource DarkGray}"/>
                </StackPanel>

                <!-- Conteudo Configuracoes -->
                <StackPanel x:Name="SettingsContent" Orientation="Vertical" Margin="24,24" Visibility="Collapsed">
                    <TextBlock Text="Configuracoes" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    
                    <StackPanel Orientation="Vertical" Margin="0,0,0,16">
                        <TextBlock Text="Notificacoes" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <CheckBox Content="Ativar notificacoes por som" Margin="0,4" FontSize="12"/>
                        <CheckBox Content="Ativar notificacoes push" Margin="0,4" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Aparencia" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <RadioButton Content="Modo Claro" IsChecked="True" Margin="0,4" FontSize="12"/>
                        <RadioButton Content="Modo Escuro" Margin="0,4" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
