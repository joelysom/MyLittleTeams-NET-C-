<local:ChromeWindow x:Class="MeuApp.MainWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:local="clr-namespace:MeuApp"
                    Title="Choas Observatório de Projetos Integradores" Height="720" Width="1280"
                    WindowState="Maximized"
                    ResizeMode="CanResize"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderThickness="0">

    <local:ChromeWindow.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF3F7FC"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FFF8FAFC"/>
        <SolidColorBrush x:Key="SidebarBorderBrush" Color="#FFE2E8F0"/>
        <SolidColorBrush x:Key="TopBarBackgroundBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MainContentBackgroundBrush" Color="#FFF8FBFF"/>
        <SolidColorBrush x:Key="SearchBackgroundBrush" Color="#FFF8FAFC"/>
        <SolidColorBrush x:Key="SearchBorderBrush" Color="#FFD8E2EE"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF0F172A"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF475569"/>
        <SolidColorBrush x:Key="TertiaryTextBrush" Color="#FF64748B"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MutedCardBackgroundBrush" Color="#FFF8FAFC"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFDBE5F0"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF2563EB"/>
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#FFE8EEFF"/>
        <SolidColorBrush x:Key="SidebarHoverBrush" Color="#FFEEF4FF"/>
        <SolidColorBrush x:Key="SidebarActiveBrush" Color="#FFE7EEFF"/>
        <SolidColorBrush x:Key="SidebarActiveBorderBrush" Color="#FFBFDBFE"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF16A34A"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFF59E0B"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FFDC2626"/>
        <SolidColorBrush x:Key="ChatIconBrush" Color="#FF0F766E"/>
        <SolidColorBrush x:Key="ConnectionsIconBrush" Color="#FF0284C7"/>
        <SolidColorBrush x:Key="TeamsIconBrush" Color="#FF2563EB"/>
        <SolidColorBrush x:Key="CalendarIconBrush" Color="#FFEA580C"/>
        <SolidColorBrush x:Key="FilesIconBrush" Color="#FF7C3AED"/>
        <SolidColorBrush x:Key="SettingsIconBrush" Color="#FF64748B"/>
        <SolidColorBrush x:Key="ToggleTrackOffBrush" Color="#FFCBD5E1"/>
        <SolidColorBrush x:Key="ToggleTrackOnBrush" Color="#FF2563EB"/>
        <SolidColorBrush x:Key="ToggleThumbBrush" Color="#FFFFFFFF"/>

        <Style x:Key="MainScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="2"
                                CornerRadius="999"
                                Background="{DynamicResource SearchBorderBrush}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ToggleTrackOnBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="MainVerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Width="{TemplateBinding Width}" Background="Transparent">
                <Border Margin="2,0"
                        CornerRadius="999"
                        Background="{DynamicResource SearchBackgroundBrush}"/>
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource MainScrollBarThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="MainHorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Height="{TemplateBinding Height}" Background="Transparent">
                <Border Margin="0,2"
                        CornerRadius="999"
                        Background="{DynamicResource SearchBackgroundBrush}"/>
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource MainScrollBarThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource MainVerticalScrollBarTemplate}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource MainHorizontalScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DisplaySectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppDisplayFontFamily}"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="SidebarNavLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconSurfaceButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="{DynamicResource MutedCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionsMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="QuickActionButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="QuickActionButtonBorder" Property="Background" Value="{DynamicResource SearchBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="QuickActionButtonBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionsMenuMiniButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="{DynamicResource MutedCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MiniButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MiniButtonBorder" Property="Background" Value="{DynamicResource AccentMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MiniButtonBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MiniButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ComboBoxItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ComboBoxItemBorder" Property="Background" Value="{DynamicResource AccentMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ComboBoxItemBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBoxItemBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogComboBoxEditableTextBoxStyle" TargetType="TextBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <Path x:Name="Arrow"
                                  Width="12"
                                  Height="7"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource SecondaryTextBrush}"
                                  Data="M 0 0 L 6 7 L 12 0 Z"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Arrow" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="{DynamicResource SearchBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DialogComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBoxBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Margin="14,0,6,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>

                                    <TextBox x:Name="PART_EditableTextBox"
                                             Grid.Column="0"
                                             Margin="14,0,6,0"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             Visibility="Hidden"
                                             Style="{StaticResource DialogComboBoxEditableTextBoxStyle}"
                                             Foreground="{TemplateBinding Foreground}"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"/>

                                    <ToggleButton Grid.Column="1"
                                                  Style="{StaticResource DialogComboBoxToggleButtonStyle}"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border x:Name="PopupBorder"
                                        Margin="0,8,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource SearchBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <ScrollViewer Margin="6"
                                                  MaxHeight="260"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBoxBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBoxBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBoxBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource DialogComboBoxStyle}"/>

        <Style x:Key="DialogListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ListBoxItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ListBoxItemBorder" Property="Background" Value="{DynamicResource AccentMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ListBoxItemBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ListBoxItemBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SearchBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="0,6,0,6">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Background="{TemplateBinding Foreground}"
                                                  BorderBrush="Transparent"
                                                  BorderThickness="0"
                                                  Height="6"
                                                  VerticalAlignment="Center">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="999"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Background="{TemplateBinding Background}"
                                                  BorderBrush="Transparent"
                                                  BorderThickness="0"
                                                  Height="6"
                                                  VerticalAlignment="Center">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="999"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18"
                                           Height="18"
                                           Background="{DynamicResource SurfaceBrush}"
                                           BorderBrush="{TemplateBinding Foreground}"
                                           BorderThickness="2">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="9"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="MinWidth" Value="54"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="54"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="54" Height="30" VerticalAlignment="Center">
                                <Border x:Name="Track"
                                        Background="{DynamicResource ToggleTrackOffBrush}"
                                        CornerRadius="15"/>
                                <Border x:Name="Thumb"
                                        Width="24"
                                        Height="24"
                                        Margin="3,0,0,0"
                                        Background="{DynamicResource ToggleThumbBrush}"
                                        CornerRadius="12"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"/>
                            </Grid>
                            <ContentPresenter Grid.Column="1"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ToggleTrackOnBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.5"/>
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:ChromeWindow.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <local:WindowTitleBar x:Name="MainWindowTitleBar"
                      Grid.Row="0"
                              Background="{DynamicResource TopBarBackgroundBrush}"
                              BorderBrush="{DynamicResource SidebarBorderBrush}"
                              BorderThickness="0,0,0,1"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              MutedForegroundBrush="{DynamicResource SecondaryTextBrush}"
                              CommandHoverBrush="{DynamicResource SearchBackgroundBrush}"
                              CloseHoverBrush="#FFFEE2E2"
                              CloseForegroundBrush="{DynamicResource DangerBrush}"
                      AccentBrush="{DynamicResource AccentBrush}"
                      AccentMutedBrush="{DynamicResource AccentMutedBrush}"
                      QuickActionsBackgroundBrush="{DynamicResource CardBackgroundBrush}"
                      QuickActionsMutedSurfaceBrush="{DynamicResource MutedCardBackgroundBrush}"
                      QuickActionsBorderBrush="{DynamicResource CardBorderBrush}"
                              WindowCommandsBackground="{DynamicResource MutedCardBackgroundBrush}"
                              WindowCommandsBorderBrush="{DynamicResource CardBorderBrush}"
                              InnerPadding="20,10"
                      TitleBarMinHeight="72"
                      ShowProfileAction="True"
                      ProfileRequested="MainWindowTitleBar_ProfileRequested">
            <local:WindowTitleBar.HeaderContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                    <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AccentMutedBrush}" Margin="0,0,12,0">
                        <iconPacks:PackIconMaterial Kind="CloudCheckOutline" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Tag="MainWindow.WelcomeText"
                               Text="Bem-vindo"
                               FontFamily="{StaticResource AppDisplayFontFamily}"
                               FontSize="18"
                               FontWeight="ExtraBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </local:WindowTitleBar.HeaderContent>

            <local:WindowTitleBar.CenterContent>
                <Border Background="{DynamicResource SearchBackgroundBrush}"
                        BorderBrush="{DynamicResource SearchBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="12,0"
                        Width="320"
                        Height="40"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Tag="MainWindow.SearchFriendsBox" Grid.Column="0" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" BorderThickness="0" VerticalAlignment="Center" Padding="8,0,0,0" mah:TextBoxHelper.Watermark="Pesquisar pessoas, equipes, chats ou arquivos..." KeyDown="SearchFriendsBox_KeyDown" TextChanged="SearchFriendsBox_TextChanged"/>
                        <Button Grid.Column="1" Background="Transparent" Foreground="{DynamicResource AccentBrush}" Padding="8" Width="40" Cursor="Hand" BorderThickness="0" Click="SearchFriends_Click">
                            <iconPacks:PackIconMaterial Kind="Magnify" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>
            </local:WindowTitleBar.CenterContent>

            <local:WindowTitleBar.RightContent>
                <Button Tag="MainWindow.TestFirebaseButton" Style="{StaticResource IconSurfaceButtonStyle}" Background="{DynamicResource AccentMutedBrush}" BorderThickness="0" Foreground="{DynamicResource AccentBrush}" Padding="0" Width="48" Height="48" Cursor="Hand" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="TestFirebase_Click" ToolTip="Teste de conexão Firebase">
                    <iconPacks:PackIconMaterial Kind="CloudCheckOutline" Width="20" Height="20" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </local:WindowTitleBar.RightContent>
        </local:WindowTitleBar>

        <Grid x:Name="MainWindowShellContentRoot" Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="288"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="False">
            <Grid Margin="14,14,14,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="14"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="SidebarBrandIconBadge"
                            Width="46"
                                Height="46"
                                CornerRadius="15"
                                Background="{DynamicResource AccentBrush}">
                            <Grid>
                                <Image Source="pack://application:,,,/img/tesseractICO.png"
                                       Width="24"
                                       Height="24"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="SidebarBrandTextPanel"
                                    Grid.Column="1"
                                    Margin="12,0,12,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Choas"
                                       FontFamily="{StaticResource AppDisplayFontFamily}"
                                       FontSize="20"
                                       FontWeight="ExtraBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Observatório de Projetos Integradores"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <TextBlock x:Name="SidebarBrandCompactText"
                                   Grid.Column="1"
                                   Text="C"
                                   FontFamily="{StaticResource AppDisplayFontFamily}"
                                   FontSize="24"
                                   FontWeight="ExtraBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>

                        <Button x:Name="SidebarCollapseButton"
                                Grid.Column="2"
                                Style="{StaticResource IconSurfaceButtonStyle}"
                                Width="36"
                                Height="36"
                                Background="{DynamicResource AccentMutedBrush}"
                                BorderThickness="0"
                                ToolTip="Expandir ou recolher a navegação"
                                Click="ToggleSidebar_Click">
                            <iconPacks:PackIconMaterial x:Name="SidebarCollapseIcon"
                                                        Kind="ChevronDoubleLeft"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="{DynamicResource AccentBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <Border x:Name="SidebarWorkspaceBadge"
                        Grid.Row="1"
                        Margin="0,12,0,14"
                        Padding="12,10"
                        Background="{DynamicResource AccentMutedBrush}"
                        CornerRadius="16">
                    <TextBlock Text="Workspace acadêmico • chats, equipes, entregas e materiais"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <StackPanel x:Name="SidebarNavPanel" Grid.Row="2" Orientation="Vertical">
                    <Button x:Name="ChatsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Chats" ToolTip="Chats">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="MessageTextOutline" Width="18" Height="18" Foreground="{DynamicResource ChatIconBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ChatsNavLabel" Text="Chats" Style="{StaticResource SidebarNavLabelStyle}"/>
                            </StackPanel>

                            <Border x:Name="ChatsUnreadBadge"
                                    Grid.Column="1"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="10"
                                    Padding="7,2"
                                    Margin="10,0,0,0"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="ChatsUnreadCountText"
                                           Text="0"
                                           Foreground="White"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button x:Name="ConnectionsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Conexoes" ToolTip="Conexões">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="HandshakeOutline" Width="18" Height="18" Foreground="{DynamicResource ConnectionsIconBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ConnectionsNavLabel" Text="Conexões" Style="{StaticResource SidebarNavLabelStyle}"/>
                            </StackPanel>

                            <Border x:Name="ConnectionsUnreadBadge"
                                    Grid.Column="1"
                                    Background="{DynamicResource SuccessBrush}"
                                    CornerRadius="10"
                                    Padding="7,2"
                                    Margin="10,0,0,0"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="ConnectionsUnreadCountText"
                                           Text="0"
                                           Foreground="White"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button x:Name="TeamsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Equipes" ToolTip="Equipes">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountGroupOutline" Width="18" Height="18" Foreground="{DynamicResource TeamsIconBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TeamsNavLabel" Text="Equipes" Style="{StaticResource SidebarNavLabelStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ProfessorNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Professor" ToolTip="Docência" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="SchoolOutline" Width="18" Height="18" Foreground="#FF7C3AED" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ProfessorNavLabel" Text="Docência" Style="{StaticResource SidebarNavLabelStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="CalendarNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Calendario" ToolTip="Calendário">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CalendarMonthOutline" Width="18" Height="18" Foreground="{DynamicResource CalendarIconBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CalendarNavLabel" Text="Calendário" Style="{StaticResource SidebarNavLabelStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="FilesNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Arquivos" ToolTip="Arquivos">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FolderOutline" Width="18" Height="18" Foreground="{DynamicResource FilesIconBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FilesNavLabel" Text="Arquivos" Style="{StaticResource SidebarNavLabelStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SettingsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Configuracoes" ToolTip="Configurações">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CogOutline" Width="18" Height="18" Foreground="{DynamicResource SettingsIconBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SettingsNavLabel" Text="Configurações" Style="{StaticResource SidebarNavLabelStyle}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3"
                        Margin="0,16,0,0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="20">
                    <Button x:Name="SidebarProfileButton"
                            Padding="14"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OpenSettings_Click">
                        <Grid x:Name="SidebarProfileLayout" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid x:Name="SidebarAvatarHost" Grid.Column="0" Width="42" Height="42"/>
                            <StackPanel x:Name="SidebarProfileDetails" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="SidebarUserName" Text="Usuário" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock x:Name="SidebarUserRole" Text="Aluno" FontSize="11" Foreground="{DynamicResource SuccessBrush}"/>
                                <TextBlock x:Name="SidebarUserEmail" Text="email@dominio.com" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Button>
                </Border>

                <Button x:Name="SidebarRestoreHandle"
                        Grid.RowSpan="4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,84,-20,0"
                        Width="30"
                        Height="72"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        ToolTip="Expandir navegação"
                        Click="ToggleSidebar_Click">
                    <iconPacks:PackIconMaterial Kind="ChevronDoubleRight"
                                                Width="16"
                                                Height="16"
                                                Foreground="White"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Column="1" Background="{DynamicResource MainContentBackgroundBrush}">
            <!-- CONTENT PANELS -->
            <Grid Background="{DynamicResource MainContentBackgroundBrush}" Margin="24,20">
                    <!-- Chats -->
                    <Grid x:Name="ChatsContent">
                        <StackPanel VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <iconPacks:PackIconMaterial Kind="MessageTextOutline" Width="20" Height="20" Foreground="{DynamicResource ChatIconBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Conversas Ativas" Style="{StaticResource DisplaySectionTitleStyle}"/>
                            </StackPanel>
                            <TextBlock Text="Selecione uma conversa para começar" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Teams -->
                    <ScrollViewer x:Name="TeamsContent" Visibility="Collapsed" VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Vertical">
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <iconPacks:PackIconMaterial Kind="AccountGroupOutline" Width="20" Height="20" Foreground="{DynamicResource TeamsIconBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Minhas Equipes" Style="{StaticResource DisplaySectionTitleStyle}"/>
                                    </StackPanel>
                                    <TextBlock Text="Gerencie grupos de projeto, convites e materiais compartilhados sem poluir a tela inicial." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="TeamSyncStatusText" Text="" FontSize="12" Margin="0,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Button x:Name="TeamEntryOptionsButton"
                                        Grid.Column="1"
                                        Width="46"
                                        Height="46"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Click="OpenTeamEntryOptions_Click">
                                    <iconPacks:PackIconMaterial Kind="Plus" Width="22" Height="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </Grid>

                            <Popup x:Name="TeamEntryOptionsPopup"
                                   PlacementTarget="{Binding ElementName=TeamEntryOptionsButton}"
                                   Placement="Bottom"
                                   HorizontalOffset="-84"
                                   VerticalOffset="10"
                                   AllowsTransparency="True"
                                   StaysOpen="False">
                                <Border Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="14"
                                        Width="220">
                                    <StackPanel>
                                        <Button Content="Ingressar em equipe"
                                                Margin="0,0,0,8"
                                                Padding="14,10"
                                                Background="{DynamicResource MutedCardBackgroundBrush}"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                BorderThickness="0"
                                                HorizontalContentAlignment="Left"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Click="ShowJoinTeam_Click"/>
                                        <Button Content="Criar equipe"
                                                Padding="14,10"
                                                Background="{DynamicResource AccentBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                HorizontalContentAlignment="Left"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Click="ShowCreateTeam_Click"/>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <Border x:Name="TeamsEmptyStateCard" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="24" Margin="0,0,0,14">
                                <StackPanel HorizontalAlignment="Center" Width="420">
                                    <TextBlock Text="Sem equipes ativas" FontSize="22" FontWeight="ExtraBold" Foreground="{DynamicResource PrimaryTextBrush}" TextAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="Quando voce criar ou ingressar em uma equipe de projeto por codigo, a organização correspondente aparecera aqui. As turmas da Docência ficam na aba própria." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,18"/>
                                    <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16">
                                        <TextBlock Text="Use o botão de nova equipe no canto superior para criar uma equipe de projeto ou cole um código para o app encaminhar você para Equipes ou Docência, conforme o destino correto." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="TeamJoinCard" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="22" Margin="0,0,0,14" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Ingressar por codigo" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <TextBlock Text="Cole o codigo da equipe de projeto ou da turma em Docência. O app identifica o destino correto e envia voce para o contexto certo automaticamente." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,18" TextWrapping="Wrap"/>

                                    <TextBlock Text="Codigo da equipe ou turma" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TeamJoinCodeTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="Ingressar agora"
                                                Width="170"
                                                Height="44"
                                                Background="{DynamicResource AccentBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Click="JoinTeamByCode_Click"/>
                                        <Button Content="Cancelar"
                                                Width="120"
                                                Height="44"
                                                Margin="10,0,0,0"
                                                Background="{DynamicResource MutedCardBackgroundBrush}"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Click="CancelTeamEntry_Click"/>
                                        <TextBlock x:Name="TeamJoinStatusText"
                                                   Text=""
                                                   Margin="16,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="TeamCreationCard" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="22" Margin="0,0,0,14" Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Criar equipe" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <Button Grid.Column="1"
                                                Content="Cancelar"
                                                Padding="14,8"
                                                Background="{DynamicResource MutedCardBackgroundBrush}"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                Cursor="Hand"
                                                Click="CancelTeamEntry_Click"/>
                                    </Grid>

                                    <TextBlock Text="Defina os dados academicos e adicione os integrantes antes de abrir o painel completo da equipe." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,18" TextWrapping="Wrap"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Nome da equipe" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="TeamNameTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="Curso" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="TeamCourseComboBox" Height="44" Padding="12,8" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" IsEditable="True"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="90" Height="90" CornerRadius="45" Background="White" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="4">
                                                <ContentControl x:Name="TeamLogoPreviewHost"
                                                                HorizontalContentAlignment="Stretch"
                                                                VerticalContentAlignment="Stretch"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Logo do projeto" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Text="Envie a identidade visual da equipe. Ao escolher a imagem, o app abre um recorte guiado com preview circular e quadrado." FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                    <Button x:Name="SelectTeamLogoButton"
                                                            Content="Escolher logo"
                                                            Padding="16,10"
                                                            MinWidth="128"
                                                            Background="{DynamicResource AccentBrush}"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            FontWeight="SemiBold"
                                                            Cursor="Hand"
                                                            Click="SelectDraftTeamLogo_Click"/>
                                                    <Button x:Name="ClearTeamLogoButton"
                                                            Content="Remover"
                                                            Margin="10,0,0,0"
                                                            Padding="14,10"
                                                            MinWidth="112"
                                                            Background="{DynamicResource CardBackgroundBrush}"
                                                            Foreground="{DynamicResource PrimaryTextBrush}"
                                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                                            FontWeight="SemiBold"
                                                            Cursor="Hand"
                                                            Click="ClearDraftTeamLogo_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Turma" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="TeamClassComboBox" Height="44" Padding="12,8" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" IsEditable="True"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="ID da turma" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="TeamClassIdTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Semestre letivo" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                            <TextBox x:Name="TeamAcademicTermTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="Modelo acadêmico" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="TeamTemplateComboBox" Height="44" Padding="12,8" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" DisplayMemberPath="Title"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="UCs" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="TeamUcInput"
                                                      Grid.Column="0"
                                                      Height="44"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="True"
                                                      StaysOpenOnEdit="True"
                                                      Padding="12,8"
                                                      Background="{DynamicResource SearchBackgroundBrush}"
                                                      BorderBrush="{DynamicResource SearchBorderBrush}"
                                                      Foreground="{DynamicResource PrimaryTextBrush}"
                                                      FontSize="13"
                                                      KeyDown="TeamUcInput_KeyDown"/>
                                            <Button Grid.Column="1"
                                                    Content="Adicionar UC"
                                                    Margin="10,0,0,0"
                                                    Padding="16,10"
                                                    MinWidth="110"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontWeight="SemiBold"
                                                    Cursor="Hand"
                                                    Click="AddTeamUc_Click"/>
                                        </Grid>
                                        <TextBlock Text="Adicione uma ou mais unidades curriculares vinculadas a esta equipe." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,8,0,8" TextWrapping="Wrap"/>
                                        <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12" MinHeight="58">
                                            <WrapPanel x:Name="TeamUcsPanel" ItemHeight="34" ItemWidth="Auto"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,18">
                                        <TextBlock Text="Adicionar alunos" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Margin="0,0,10,0">
                                                <TextBlock Text="Entrada inicial" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="TeamMemberRoleComboBox" Height="40" Padding="12,8" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" IsEnabled="False">
                                                    <ComboBoxItem Content="Aluno" Tag="student"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <Border Grid.Column="1" Margin="10,20,0,0" Padding="12" Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12">
                                                <TextBlock x:Name="TeamMemberRoleHintText" Text="Toda nova entrada começa como aluno. A liderança discente é definida depois pelo professor focal." FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                            </Border>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="TeamMemberInput"
                                                      Grid.Column="0"
                                                      Height="44"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="False"
                                                      StaysOpenOnEdit="True"
                                                      DisplayMemberPath="DisplayLabel"
                                                      Padding="12,8"
                                                      Background="{DynamicResource SearchBackgroundBrush}"
                                                      BorderBrush="{DynamicResource SearchBorderBrush}"
                                                      Foreground="{DynamicResource PrimaryTextBrush}"
                                                      FontSize="13"
                                                      SelectionChanged="TeamMemberInput_SelectionChanged"
                                                      KeyDown="TeamMemberInput_KeyDown"/>
                                            <Button Grid.Column="1"
                                                    Content="Adicionar participante"
                                                    Margin="10,0,0,0"
                                                    Padding="16,10"
                                                    MinWidth="126"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontWeight="SemiBold"
                                                    Cursor="Hand"
                                                    Click="AddTeamMember_Click"/>
                                        </Grid>
                                        <TextBlock Text="Digite o nome e confirme a entrada do aluno. Depois, se necessário, o professor focal define a liderança discente da equipe." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,8,0,8" TextWrapping="Wrap"/>
                                        <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12" MinHeight="58">
                                            <WrapPanel x:Name="TeamMembersPanel" ItemHeight="34" ItemWidth="Auto"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="CreateTeamButton"
                                                Content="Criar equipe"
                                                Width="180"
                                                Height="44"
                                                Background="{DynamicResource AccentBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Click="CreateTeam_Click"/>
                                        <TextBlock x:Name="TeamCreationStatusText"
                                                   Text=""
                                                   Margin="16,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="TeamListCard" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="22" Margin="0,0,0,14" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Equipes cadastradas" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <TextBlock Text="Selecione uma equipe para abrir os detalhes, materiais e painéis de gestão." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16" TextWrapping="Wrap"/>
                                    <TextBox x:Name="TeamListSearchBox"
                                             Height="42"
                                             Padding="12,10"
                                             Margin="0,0,0,8"
                                             Background="{DynamicResource SearchBackgroundBrush}"
                                             BorderBrush="{DynamicResource SearchBorderBrush}"
                                             Foreground="{DynamicResource PrimaryTextBrush}"
                                             FontSize="13"
                                             TextChanged="TeamListSearchBox_TextChanged"/>
                                    <TextBlock x:Name="TeamListSearchStatusText"
                                               Text=""
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,0,0,12"
                                               TextWrapping="Wrap"/>
                                    <StackPanel x:Name="TeamListPanel"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="TeamWorkspaceCard" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="0" Visibility="Collapsed">
                                <ContentControl x:Name="TeamWorkspaceHost"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Connections -->
                    <ScrollViewer x:Name="ConnectionsContent" Visibility="Collapsed" VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Vertical">
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <iconPacks:PackIconMaterial Kind="HandshakeOutline" Width="20" Height="20" Foreground="{DynamicResource ConnectionsIconBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Minhas conexões" Style="{StaticResource DisplaySectionTitleStyle}"/>
                                    </StackPanel>
                                    <TextBlock Text="Acompanhe solicitações pendentes, respostas recebidas e sua rede acadêmica em um só lugar." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Atualizar"
                                        Width="120"
                                        Height="42"
                                        Background="{DynamicResource MutedCardBackgroundBrush}"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Click="RefreshConnections_Click"/>
                            </Grid>

                            <TextBlock x:Name="ConnectionsStatusText" Text="" FontSize="12" Margin="0,0,0,14" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            <StackPanel x:Name="ConnectionsSectionsHost" Orientation="Vertical"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Professor Dashboard -->
                    <Grid x:Name="ProfessorDashboardContent" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Vertical" Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <iconPacks:PackIconMaterial Kind="SchoolOutline" Width="20" Height="20" Foreground="#FF7C3AED" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Docência" Style="{StaticResource DisplaySectionTitleStyle}"/>
                            </StackPanel>
                            <TextBlock Text="Abra cada turma em página própria, gerencie alunos e códigos de entrada e mantenha os projetos integradores fora deste fluxo." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="ProfessorDashboardStatusText" Text="" FontSize="12" Margin="0,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ProfessorDashboardHost" Orientation="Vertical" Margin="0,0,0,24"/>
                        </ScrollViewer>
                    </Grid>

                    <!-- Calendar -->
                    <Grid x:Name="CalendarContent" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Vertical" Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <iconPacks:PackIconMaterial Kind="CalendarMonthOutline" Width="20" Height="20" Foreground="{DynamicResource CalendarIconBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Calendário" Style="{StaticResource DisplaySectionTitleStyle}"/>
                            </StackPanel>
                            <TextBlock Text="Visualize o mês em grid no estilo iOS. Dias sem marcação ficam estáticos; dias com prazo, evento ou reunião abrem os detalhes ao clicar." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="CalendarStatusText" Text="" FontSize="12" Margin="0,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CalendarAgendaHost" Orientation="Vertical" Margin="0,0,0,24"/>
                        </ScrollViewer>
                    </Grid>

                    <!-- Files -->
                    <Grid x:Name="FilesContent" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <iconPacks:PackIconMaterial Kind="FolderOutline" Width="20" Height="20" Foreground="{DynamicResource FilesIconBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Arquivos" Style="{StaticResource DisplaySectionTitleStyle}"/>
                                </StackPanel>
                                <TextBlock Text="Monte sua mochila de materiais, marque o contexto e deixe o CHOAS lembrar onde cada peça entra." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="FilesStatusText" Text="" FontSize="12" Margin="0,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Visibility="Collapsed"/>
                            </StackPanel>

                            <Button x:Name="FilesAddButton"
                                    Grid.Column="1"
                                    Width="46"
                                    Height="46"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    ToolTip="Adicionar arquivos"
                                    Click="AddFilesHub_Click">
                                <iconPacks:PackIconMaterial Kind="Plus" Width="22" Height="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1">
                            <ScrollViewer VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="FilesHubScrollStack" Margin="0,0,0,316">
                                    <WrapPanel x:Name="FilesHubSummaryHost" Margin="0,0,0,12"/>
                                    <StackPanel x:Name="FilesHubBodyHost" Orientation="Vertical"/>
                                </StackPanel>
                            </ScrollViewer>

                            <Border x:Name="FilesChoasHost"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,16"
                                    Background="Transparent"/>
                        </Grid>
                    </Grid>

                    <!-- Settings -->
                    <ScrollViewer x:Name="SettingsContent" Visibility="Collapsed" VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <iconPacks:PackIconMaterial Kind="CogOutline" Width="20" Height="20" Foreground="{DynamicResource SettingsIconBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Configurações" Style="{StaticResource DisplaySectionTitleStyle}"/>
                        </StackPanel>
                        <TextBlock Text="Gerencie sua sessão, notificações e atalhos do ambiente colaborativo." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,18"/>

                        <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="22" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Perfil profissional" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Text="Complete sua apresentação acadêmica e profissional. O nome da conta permanece fixo, mas você pode enriquecer o restante do perfil." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,18" TextWrapping="Wrap"/>

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                        <Button x:Name="AvatarEditorButton"
                                            Width="168"
                                            Height="168"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="OpenPrimaryProfileIdentity_Click">
                                        <Grid>
                                            <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="24"/>
                                            <Grid x:Name="ProfileAvatarPreviewHost" Margin="18"/>
                                        </Grid>
                                    </Button>

                                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Avatar do perfil" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock x:Name="AvatarEditorHintText" Text="Sem avatar ainda. Clique para criar seu ícone." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,8,0,12" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="AvatarEditorSupportText" Text="Monte seu avatar por camadas: corpo e cabelo são obrigatórios, acessório é opcional." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,0,0,14" TextWrapping="Wrap"/>
                                        <WrapPanel>
                                            <Button x:Name="AvatarActionButton"
                                                Content="Criar seu ícone"
                                                Width="160"
                                                Height="40"
                                                Background="{DynamicResource AccentBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Click="OpenAvatarEditor_Click"/>
                                            <Button x:Name="ProfilePhotoActionButton"
                                                Content="Adicionar foto"
                                                Width="160"
                                                Height="40"
                                                Margin="10,0,0,0"
                                                Background="{DynamicResource MutedCardBackgroundBrush}"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="1"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Click="UploadProfilePhoto_Click"/>
                                            <Button x:Name="RemoveProfilePhotoButton"
                                                Content="Remover foto"
                                                Width="140"
                                                Height="40"
                                                Margin="10,0,0,0"
                                                Background="{DynamicResource MutedCardBackgroundBrush}"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="1"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Visibility="Collapsed"
                                                Click="RemoveProfilePhoto_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Nome da conta" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                                            <TextBlock x:Name="AccountNameText" Text="Usuário" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Nickname profissional" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="NicknameTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Descrição curta" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="ProfessionalTitleTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Linguagens de programação" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="ProgrammingLanguageInput"
                                                      Grid.Column="0"
                                                      Height="44"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="True"
                                                      StaysOpenOnEdit="True"
                                                      Padding="12,8"
                                                      Background="{DynamicResource SearchBackgroundBrush}"
                                                      BorderBrush="{DynamicResource SearchBorderBrush}"
                                                      Foreground="{DynamicResource PrimaryTextBrush}"
                                                      FontSize="13"
                                                      KeyDown="ProgrammingLanguageInput_KeyDown"/>
                                            <Button Grid.Column="1"
                                                    Content="Adicionar"
                                                    Margin="10,0,0,0"
                                                    Padding="16,10"
                                                    MinWidth="96"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontWeight="SemiBold"
                                                    Cursor="Hand"
                                                    Click="AddProgrammingLanguage_Click"/>
                                        </Grid>
                                        <TextBlock Text="Digite ou selecione uma linguagem e pressione Enter. Ela aparecerá como tag removível logo abaixo." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,8,0,8" TextWrapping="Wrap"/>
                                        <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12" MinHeight="58">
                                            <WrapPanel x:Name="ProgrammingLanguagesTagsPanel" ItemHeight="34" ItemWidth="Auto"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Área acadêmica" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="AcademicDepartmentTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Foco acadêmico" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="AcademicFocusTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Janela de atendimento" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="OfficeHoursTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Perfil e acesso" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                                            <StackPanel>
                                                <TextBlock x:Name="AccountRoleText" Text="Aluno" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="ProfessorAccessText" Text="student-workspace" Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Bio" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="BioTextBox" Height="92" Padding="12,12" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Habilidades" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="SkillsTextBox" Height="76" Padding="12,12" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                </StackPanel>

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Link do portfólio" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="PortfolioLinkTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Link do LinkedIn" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="LinkedInLinkTextBox" Height="44" Padding="12,10" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Galeria do currículo" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Text="Adicione imagens avulsas ou monte uma galeria em pasta para eventos, bancas e entregas. Toda imagem continua passando pelo recorte antes de entrar no perfil." FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,0,0,0">
                                                <Button x:Name="AddProfileGalleryButton"
                                                        Content="Adicionar imagens"
                                                        MinWidth="144"
                                                        Height="36"
                                                        Background="{DynamicResource AccentBrush}"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        FontWeight="SemiBold"
                                                        Cursor="Hand"
                                                        Click="AddProfileGalleryImages_Click"/>
                                                <Button x:Name="AddProfileGalleryAlbumButton"
                                                        Content="Adicionar galeria em pasta"
                                                        MinWidth="188"
                                                        Height="36"
                                                        Margin="10,0,0,0"
                                                        Background="{DynamicResource MutedCardBackgroundBrush}"
                                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        FontWeight="SemiBold"
                                                        Cursor="Hand"
                                                        Click="AddProfileGalleryAlbum_Click"/>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock x:Name="ProfileGalleryStatusText" Text="Você pode manter até 6 imagens no currículo." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,10,0,12" TextWrapping="Wrap"/>
                                        <WrapPanel x:Name="ProfileGalleryHost"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Text="Projetos no currículo" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Selecione quais equipes devem aparecer no seu perfil. Os detalhes e imagens do projeto continuam respeitando a permissão da equipe." FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,10" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="ProfileProjectHighlightsStatusText" Text="Carregando equipes vinculadas ao perfil..." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                        <StackPanel x:Name="ProfileProjectHighlightsHost"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="SaveProfessionalProfileButton"
                                            Content="Salvar perfil profissional"
                                            Width="220"
                                            Height="44"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Click="SaveProfessionalProfile_Click"/>
                                    <TextBlock x:Name="ProfessionalProfileStatusText"
                                               Text=""
                                               Margin="16,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource MutedCardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="20" Margin="0,0,0,14">
                            <StackPanel>
                            <TextBlock Text="Sessão Atual" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Use esta área para encerrar sua sessão com segurança e retornar à tela de login." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16" TextWrapping="Wrap"/>
                                <Button x:Name="LogoutButton"
                                        Content="Sair da conta"
                                        Width="160"
                                        Height="42"
                                        HorizontalAlignment="Left"
                                        Background="#FFDC2626"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Click="LogoutButton_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Preferências rápidas" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Text="Base de notificações e monitoramento do observatório." FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,16"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Alertas de mensagens" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Receba avisos quando novas interações chegarem." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Ativo" Foreground="#FF0F766E" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Sincronização em tempo real" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Mantém conversas e salas sempre atualizadas." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Online" Foreground="#FF2563EB" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Contato acadêmico" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Professor orientador e canal de suporte do projeto." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Disponível" Foreground="#FF7C3AED" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                            <TextBlock Text="Modo escuro do aplicativo" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="Escurece toda a interface do app, incluindo sidebar, topo, áreas de conteúdo e conversas." FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}" TextWrapping="Wrap" MaxWidth="360"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChatDarkModeToggle"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"
                                                Style="{StaticResource ToggleSwitchStyle}"
                                              Checked="ChatDarkModeToggle_Changed"
                                              Unchecked="ChatDarkModeToggle_Changed"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid x:Name="SearchSlideOverlay"
                          Visibility="Collapsed"
                          Panel.ZIndex="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="620"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Background="#3B020617"
                                BorderThickness="0"
                                Cursor="Arrow"
                                Click="CloseSearchSlide_Click"/>

                        <Border x:Name="SearchSlidePanel"
                                Grid.Column="1"
                                Margin="16,0,0,0"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="28,0,0,28"
                                Padding="0"
                                Opacity="0">
                            <Border.RenderTransform>
                                <TranslateTransform X="56"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Background="{DynamicResource MutedCardBackgroundBrush}" CornerRadius="28,0,0,0" Padding="22,20,22,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock x:Name="SearchSlideTitleText"
                                                       Text="Pesquisar conexões"
                                                       FontSize="18"
                                                       FontWeight="ExtraBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="Busque por nome, matrícula ou email com resultados vivos enquanto você digita."
                                                       Margin="0,6,0,0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="✕"
                                                Width="40"
                                                Height="40"
                                                Margin="12,0,0,0"
                                                Background="Transparent"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                BorderThickness="0"
                                                FontSize="14"
                                                Cursor="Hand"
                                                Click="CloseSearchSlide_Click"/>
                                    </Grid>
                                </Border>

                                <TextBlock x:Name="SearchSlideStatusText"
                                           Grid.Row="1"
                                           Text=""
                                           Margin="22,16,22,14"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                                <ScrollViewer Grid.Row="2"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="22,0,22,22">
                                    <StackPanel>
                                        <TextBlock x:Name="SearchSlideEmptyStateText"
                                                   Text=""
                                                   Visibility="Collapsed"
                                                   Margin="0,8,0,4"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <StackPanel x:Name="SearchSlideResultsHost" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
        </Grid>
        </Grid>
        </Grid>

    </Grid>
</local:ChromeWindow>
