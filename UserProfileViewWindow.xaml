<mah:MetroWindow x:Class="MeuApp.UserProfileViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="Perfil acadêmico" Height="900" Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FFF6F8FB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="24" Padding="24" BorderBrush="#FFE2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="108" Height="108" CornerRadius="24" Background="#FFF8FAFC" BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="4">
                    <ContentControl x:Name="AvatarHost"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}" FontSize="28" FontWeight="Bold" Foreground="#FF0F172A"/>
                    <TextBlock Text="{Binding Headline}" Margin="0,8,0,0" FontSize="14" Foreground="#FF334155" TextWrapping="Wrap"/>
                    <WrapPanel Margin="0,14,0,0">
                        <Border Background="#FFEFF6FF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                            <TextBlock Text="{Binding CourseBadge}" Foreground="#FF1D4ED8" FontWeight="SemiBold" FontSize="11"/>
                        </Border>
                        <Border Background="#FFF1F5F9" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                            <TextBlock Text="{Binding RegistrationBadge}" Foreground="#FF334155" FontWeight="SemiBold" FontSize="11"/>
                        </Border>
                        <Border Background="#FFF0FDF4" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                            <TextBlock Text="{Binding LanguagesBadge}" Foreground="#FF166534" FontWeight="SemiBold" FontSize="11"/>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,18">
            <StackPanel>
                <Border Background="White" CornerRadius="20" Padding="22" BorderBrush="#FFE2E8F0" BorderThickness="1" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Resumo profissional" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A"/>
                        <TextBlock Text="{Binding ProfessionalSummary}" Margin="0,12,0,0" FontSize="13" Foreground="#FF334155" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="20" Padding="22" BorderBrush="#FFE2E8F0" BorderThickness="1" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Galeria do currículo" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A"/>
                        <TextBlock Text="Imagens e blocos de galeria publicados pelo aluno no perfil profissional." Margin="0,8,0,0" FontSize="12" Foreground="#FF64748B"/>

                        <TextBlock Text="{Binding EmptyGalleryMessage}" Visibility="{Binding EmptyGalleryVisibility}" Margin="0,12,0,0" FontSize="12" Foreground="#FF64748B" TextWrapping="Wrap"/>

                        <ItemsControl ItemsSource="{Binding GalleryImages}" Visibility="{Binding GalleryVisibility}" Margin="0,14,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="PreviewImage_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,12,12" Cursor="Hand">
                                        <Border Width="{Binding CardWidth}" Height="{Binding CardHeight}" CornerRadius="18" Background="#FFF8FAFC" BorderBrush="#FFE2E8F0" BorderThickness="1" ClipToBounds="True">
                                            <Grid>
                                                <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                                                <Border Background="#E60F172A" CornerRadius="999" Padding="10,5" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Visibility="{Binding CountLabelVisibility}">
                                                    <TextBlock Text="{Binding CountLabel}" FontWeight="SemiBold" FontSize="10" Foreground="White"/>
                                                </Border>
                                                <Border VerticalAlignment="Bottom" Background="#CC0F172A" Padding="12,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding CardText}" FontSize="10" Foreground="#FFE2E8F0" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="20" Padding="22" BorderBrush="#FFE2E8F0" BorderThickness="1" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="Contato" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A"/>
                            <TextBlock Text="Email" Margin="0,14,0,0" FontSize="11" Foreground="#FF64748B"/>
                            <TextBlock Text="{Binding EmailValue}" FontSize="13" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                            <TextBlock Text="Telefone" Margin="0,14,0,0" FontSize="11" Foreground="#FF64748B"/>
                            <TextBlock Text="{Binding PhoneValue}" FontSize="13" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                            <TextBlock Text="Acadêmico" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A"/>
                            <TextBlock Text="Curso" Margin="0,14,0,0" FontSize="11" Foreground="#FF64748B"/>
                            <TextBlock Text="{Binding CourseValue}" FontSize="13" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                            <TextBlock Text="Matrícula" Margin="0,14,0,0" FontSize="11" Foreground="#FF64748B"/>
                            <TextBlock Text="{Binding RegistrationValue}" FontSize="13" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="20" Padding="22" BorderBrush="#FFE2E8F0" BorderThickness="1" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Competências" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A"/>
                        <TextBlock Text="Tecnologias e habilidades preenchidas pelo aluno." Margin="0,8,0,0" FontSize="12" Foreground="#FF64748B"/>
                        <TextBlock Text="{Binding SkillsValue}" Margin="0,12,0,0" FontSize="13" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="20" Padding="22" BorderBrush="#FFE2E8F0" BorderThickness="1" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Projetos em destaque" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A"/>
                        <TextBlock Text="Projetos que o aluno escolheu exibir no perfil. Apenas itens acessíveis pelas suas permissões aparecem aqui." Margin="0,8,0,0" FontSize="12" Foreground="#FF64748B" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding RestrictedProjectsNote}" Visibility="{Binding RestrictedProjectsNoteVisibility}" Margin="0,10,0,0" FontSize="12" Foreground="#FFB45309" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding EmptyFeaturedProjectsMessage}" Visibility="{Binding EmptyFeaturedProjectsVisibility}" Margin="0,12,0,0" FontSize="12" Foreground="#FF64748B" TextWrapping="Wrap"/>

                        <ItemsControl ItemsSource="{Binding FeaturedProjects}" Visibility="{Binding FeaturedProjectsVisibility}" Margin="0,14,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF8FAFC" CornerRadius="18" Padding="16" BorderBrush="#FFE2E8F0" BorderThickness="1" Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="Bold" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Subtitle}" Margin="0,6,0,0" FontSize="12" Foreground="#FF64748B" TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <Border Grid.Column="1" Background="#FFEFF6FF" CornerRadius="999" Padding="10,5" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding ProgressLabel}" Foreground="#FF1D4ED8" FontWeight="SemiBold" FontSize="11"/>
                                                </Border>
                                            </Grid>

                                            <WrapPanel Margin="0,12,0,0">
                                                <Border Background="#FFF1F5F9" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="#FF334155" FontWeight="SemiBold" FontSize="11"/>
                                                </Border>
                                                <Border Background="#FFF8FAFC" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding MembersLabel}" Foreground="#FF475569" FontWeight="SemiBold" FontSize="11"/>
                                                </Border>
                                                <Border Background="#FFF0FDF4" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding DeadlineLabel}" Foreground="#FF166534" FontWeight="SemiBold" FontSize="11"/>
                                                </Border>
                                            </WrapPanel>

                                            <TextBlock Text="{Binding Summary}" Margin="0,12,0,0" FontSize="12" Foreground="#FF334155" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding UpdatedAtLabel}" Margin="0,8,0,0" FontSize="11" Foreground="#FF64748B"/>
                                            <TextBlock Text="{Binding ProfessorFocusLabel}" Margin="0,10,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding SupervisorLabel}" Visibility="{Binding SupervisorLabelVisibility}" Margin="0,6,0,0" FontSize="11" Foreground="#FF64748B" TextWrapping="Wrap"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                <Button Content="Abrir equipe" Width="132" Height="36" Click="OpenPortfolioTeam_Click" Tag="{Binding}" Visibility="{Binding OpenTeamActionVisibility}"/>
                                                <Button Content="{Binding ClaimProfessorActionLabel}" Width="190" Height="36" Margin="10,0,0,0" Click="ClaimProfessorFocus_Click" Tag="{Binding}" Visibility="{Binding ClaimProfessorActionVisibility}" IsEnabled="{Binding CanClaimProfessorFocus}"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding EmptyPreviewMessage}" Visibility="{Binding EmptyPreviewVisibility}" Margin="0,12,0,0" FontSize="12" Foreground="#FF64748B" TextWrapping="Wrap"/>

                                            <ItemsControl ItemsSource="{Binding PreviewImages}" Visibility="{Binding PreviewImagesVisibility}" Margin="0,14,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Click="PreviewImage_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,10" Cursor="Hand">
                                                            <Border Width="{Binding CardWidth}" Height="{Binding CardHeight}" CornerRadius="16" Background="#FFF1F5F9" BorderBrush="#FFE2E8F0" BorderThickness="1" ClipToBounds="True">
                                                                <Grid>
                                                                    <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                                                                    <Border Background="#E60F172A" CornerRadius="999" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Visibility="{Binding CountLabelVisibility}">
                                                                        <TextBlock Text="{Binding CountLabel}" FontWeight="SemiBold" FontSize="9" Foreground="White"/>
                                                                    </Border>
                                                                    <Border VerticalAlignment="Bottom" Background="#CC0F172A" Padding="8,6">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="{Binding CardText}" FontSize="9" Foreground="#FFE2E8F0" TextTrimming="CharacterEllipsis"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="20" Padding="22" BorderBrush="#FFE2E8F0" BorderThickness="1" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Equipes e projetos vinculados" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A"/>
                        <TextBlock Text="{Binding PortfolioSectionDescription}" Margin="0,8,0,0" FontSize="12" Foreground="#FF64748B" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding EmptyPortfolioTeamsMessage}" Visibility="{Binding EmptyPortfolioTeamsVisibility}" Margin="0,12,0,0" FontSize="12" Foreground="#FF64748B" TextWrapping="Wrap"/>

                        <ItemsControl ItemsSource="{Binding PortfolioTeams}" Visibility="{Binding PortfolioTeamsVisibility}" Margin="0,14,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF8FAFC" CornerRadius="18" Padding="16" BorderBrush="#FFE2E8F0" BorderThickness="1" Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="Bold" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Subtitle}" Margin="0,6,0,0" FontSize="12" Foreground="#FF64748B" TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <Border Grid.Column="1" Background="#FFEFF6FF" CornerRadius="999" Padding="10,5" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding ProgressLabel}" Foreground="#FF1D4ED8" FontWeight="SemiBold" FontSize="11"/>
                                                </Border>
                                            </Grid>

                                            <WrapPanel Margin="0,12,0,0">
                                                <Border Background="#FFF1F5F9" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding StatusLabel}" Foreground="#FF334155" FontWeight="SemiBold" FontSize="11"/>
                                                </Border>
                                                <Border Background="#FFF8FAFC" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding MembersLabel}" Foreground="#FF475569" FontWeight="SemiBold" FontSize="11"/>
                                                </Border>
                                                <Border Background="#FFF0FDF4" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding DeadlineLabel}" Foreground="#FF166534" FontWeight="SemiBold" FontSize="11"/>
                                                </Border>
                                            </WrapPanel>

                                            <TextBlock Text="{Binding ProfessorFocusLabel}" Margin="0,12,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding SupervisorLabel}" Visibility="{Binding SupervisorLabelVisibility}" Margin="0,6,0,0" FontSize="11" Foreground="#FF64748B" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Summary}" Margin="0,12,0,0" FontSize="12" Foreground="#FF334155" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding UpdatedAtLabel}" Margin="0,8,0,0" FontSize="11" Foreground="#FF64748B"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                <Button Content="Abrir equipe" Width="132" Height="36" Click="OpenPortfolioTeam_Click" Tag="{Binding}" Visibility="{Binding OpenTeamActionVisibility}"/>
                                                <Button Content="{Binding ClaimProfessorActionLabel}" Width="190" Height="36" Margin="10,0,0,0" Click="ClaimProfessorFocus_Click" Tag="{Binding}" Visibility="{Binding ClaimProfessorActionVisibility}" IsEnabled="{Binding CanClaimProfessorFocus}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="20" Padding="22" BorderBrush="#FFE2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Links profissionais" FontSize="18" FontWeight="Bold" Foreground="#FF0F172A"/>
                        <TextBlock Text="Portfólio" Margin="0,14,0,0" FontSize="11" Foreground="#FF64748B"/>
                        <TextBlock Text="{Binding PortfolioValue}" FontSize="13" Foreground="#FF0F172A" TextWrapping="Wrap"/>
                        <TextBlock Text="LinkedIn" Margin="0,14,0,0" FontSize="11" Foreground="#FF64748B"/>
                        <TextBlock Text="{Binding LinkedInValue}" FontSize="13" Foreground="#FF0F172A" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button x:Name="OpenPortfolioButton" Content="Abrir portfólio" Width="140" Height="38" Margin="0,0,10,0" Click="OpenPortfolio_Click"/>
                            <Button x:Name="OpenLinkedInButton" Content="Abrir LinkedIn" Width="140" Height="38" Click="OpenLinkedIn_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Fechar" Width="120" Height="40" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
