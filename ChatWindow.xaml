<local:ChromeWindow x:Class="MeuApp.ChatWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:local="clr-namespace:MeuApp"
    Title="Choas | Conversas" Height="720" Width="1400"
    WindowState="Maximized"
    ResizeMode="CanResize"
    Background="{DynamicResource MainContentBackgroundBrush}"
    BorderThickness="0">

    <local:ChromeWindow.Resources>
        <Style x:Key="ChatSidebarFilterButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="{DynamicResource SearchBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:ChromeWindow.Resources>

    <Grid Background="{DynamicResource MainContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <local:WindowTitleBar Grid.Row="0"
                              Background="{DynamicResource CardBackgroundBrush}"
                              BorderBrush="{DynamicResource SidebarBorderBrush}"
                              BorderThickness="0,0,0,1"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              MutedForegroundBrush="#FF64748B"
                              CommandHoverBrush="{DynamicResource SearchBackgroundBrush}"
                              CloseHoverBrush="#FFFEE2E2"
                              CloseForegroundBrush="#FFDC2626"
                              AccentBrush="{DynamicResource AccentBrush}"
                              AccentMutedBrush="{DynamicResource AccentMutedBrush}"
                              QuickActionsBackgroundBrush="{DynamicResource CardBackgroundBrush}"
                              QuickActionsMutedSurfaceBrush="{DynamicResource SearchBackgroundBrush}"
                              QuickActionsBorderBrush="{DynamicResource SearchBorderBrush}"
                              WindowCommandsBackground="{DynamicResource SearchBackgroundBrush}"
                              WindowCommandsBorderBrush="{DynamicResource SearchBorderBrush}"
                              InnerPadding="20,10"
                              TitleBarMinHeight="72">
            <local:WindowTitleBar.HeaderContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="34" Height="34" Fill="#FFE8EEFF" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Conversas" FontFamily="{StaticResource AppDisplayFontFamily}" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Chat direto, histórico e presença do workspace" FontSize="11" Foreground="#FF64748B"/>
                    </StackPanel>
                </StackPanel>
            </local:WindowTitleBar.HeaderContent>
        </local:WindowTitleBar>

        <Grid Grid.Row="1" Background="{DynamicResource MainContentBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR - LISTA DE CONVERSAS -->
        <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Orientation="Vertical">
                <!-- Header -->
            <Border Padding="16,12" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="💬 Conversas" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="➕" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="16" Padding="8" Width="40" Height="40" Cursor="Hand" BorderThickness="0" ToolTip="Nova conversa"/>
                        <Button x:Name="ConversationSortButton" Grid.Column="2" Content="⋮" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16" Padding="8" Width="40" Height="40" Cursor="Hand" BorderThickness="0" ToolTip="Classificar conversas" Click="ConversationSortButton_Click">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="CustomSortMenuItem" Header="Personalizada" Click="CustomSortMenuItem_Click"/>
                                    <MenuItem x:Name="MostRecentSortMenuItem" Header="Mais recentes" Click="MostRecentSortMenuItem_Click"/>
                                    <MenuItem x:Name="UnreadOnlySortMenuItem" Header="Somente não lidos" Click="UnreadOnlySortMenuItem_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                </Border>

                <!-- Search Bar -->
                <Border Padding="12" Background="{DynamicResource CardBackgroundBrush}">
                    <Border Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" BorderThickness="1" CornerRadius="20" Padding="12,0" Height="36">
                        <TextBox Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" BorderThickness="0" VerticalAlignment="Center" mah:TextBoxHelper.Watermark="🔍 Pesquisar conversas..."/>
                    </Border>
                </Border>

                <Border Padding="12,0,12,12" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="FavoritesFilterButton"
                                    Style="{StaticResource ChatSidebarFilterButtonStyle}"
                                    Content="Favoritos"
                                    Click="FavoritesFilterButton_Click"/>
                            <Button x:Name="AllChatsFilterButton"
                                    Style="{StaticResource ChatSidebarFilterButtonStyle}"
                                    Content="Chats"
                                    Click="AllChatsFilterButton_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="ConversationSortStatusText"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="Personalizada"/>
                    </Grid>
                </Border>

                <!-- Conversations List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ConversationsList" Orientation="Vertical"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- MAIN CHAT AREA -->
        <Grid Grid.Column="1" Background="{DynamicResource MainContentBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR - Informações do contato -->
            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="44" Height="44" Fill="#FF0078D4" Margin="0,0,12,0">
                            <Ellipse.ToolTip>Avatar do contato</Ellipse.ToolTip>
                        </Ellipse>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock x:Name="ContactNameText" Text="Nome do Contato" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock x:Name="ContactStatusText" Text="Online" FontSize="12" Foreground="#FF107C10"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                        <Button Content="📞" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="18" Padding="8" Width="48" Height="48" Cursor="Hand" BorderThickness="0" ToolTip="Chamar"/>
                        <Button Content="📹" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="18" Padding="8" Width="48" Height="48" Cursor="Hand" BorderThickness="0" ToolTip="Videochamada"/>
                        <Button Content="ℹ️" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="18" Padding="8" Width="48" Height="48" Cursor="Hand" BorderThickness="0" ToolTip="Informações do contato"/>
                        <Button Content="⋮" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="18" Padding="8" Width="48" Height="48" Cursor="Hand" BorderThickness="0" ToolTip="Mais opções"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MESSAGES AREA -->
            <Border Grid.Row="1" Background="{DynamicResource MainContentBackgroundBrush}" Padding="24,20">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" x:Name="MessagesScrollViewer">
                        <StackPanel x:Name="MessagesList" Orientation="Vertical" Background="{DynamicResource MainContentBackgroundBrush}"/>
                    </ScrollViewer>

                    <StackPanel x:Name="SelfChatPlaceholderPanel"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="420">
                        <Image Source="pack://application:,,,/img/Chat/CheeseOwnChatTransparent.png"
                               Width="240"
                               Height="340"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"/>
                        <TextBlock Text="Aqui é o Chat com você mesmo, pode deixar seus textos, anotações, fotos e aquivos."
                                   Margin="0,18,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- INPUT AREA -->
            <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,1,0,0" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Message Input -->
                    <Border Grid.Column="0" Background="{DynamicResource SearchBackgroundBrush}" BorderBrush="{DynamicResource SearchBorderBrush}" BorderThickness="1" CornerRadius="24" Padding="16,0" Height="44" VerticalAlignment="Center">
                        <TextBox x:Name="MessageInput" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" BorderThickness="0" VerticalAlignment="Center" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="120" mah:TextBoxHelper.Watermark="Escreva uma mensagem..."/>
                    </Border>

                    <!-- Attach File Button -->
                    <Button Grid.Column="1" Content="📎" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="16" Padding="16,0" Width="44" Height="44" Cursor="Hand" BorderThickness="0" ToolTip="Anexar arquivo" Margin="12,0,0,0" Click="AttachFileButton_Click"/>

                    <!-- Emoji Button -->
                    <Button Grid.Column="2" Content="😊" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="16" Padding="16,0" Width="44" Height="44" Cursor="Hand" BorderThickness="0" ToolTip="Adicionar emoji" Margin="8,0,0,0"/>

                    <!-- Send Button -->
                    <Button Grid.Column="3" x:Name="SendButton" Content="➤" Background="#FF0078D4" Foreground="White" FontSize="16" Padding="0" Width="44" Height="44" Cursor="Hand" BorderThickness="0" ToolTip="Enviar mensagem (Enter)" Click="SendButton_Click" Margin="8,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</local:ChromeWindow>
