<mah:MetroWindow x:Class="MeuApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="Observatório de Projetos Integradores - Login" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="White"
        BorderThickness="0"
        AllowsTransparency="False"
        ResizeMode="NoResize">

    <mah:MetroWindow.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF0078D4"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#FFF3F3F3"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FF1F1F1F"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF717171"/>
        
        <Style x:Key="LoginInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground">
                <Setter.Value>
                    <SolidColorBrush Color="#FF1F1F1F"/>
                </Setter.Value>
            </Setter>
            <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FF0078D4"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground">
                <Setter.Value>
                    <SolidColorBrush Color="#FF1F1F1F"/>
                </Setter.Value>
            </Setter>
            <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF0063B1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FF0078D4"/>
            <Setter Property="FontFamily" Value="{StaticResource AppTextFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderBrush" Value="#FFD0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF3F3F3"/>
                                <Setter Property="BorderBrush" Value="#FFA0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF717171"/>
            <Setter Property="FontFamily" Value="{StaticResource AppDisplayFontFamily}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,8,0,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,32,0"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LADO ESQUERDO - IMAGEM -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF081223" Offset="0"/>
                    <GradientStop Color="#FF0D2A52" Offset="0.45"/>
                    <GradientStop Color="#FF1D4ED8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Ellipse Width="420" Height="420" Fill="#1FFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-120,-110,0,0"/>
                <Ellipse Width="360" Height="360" Fill="#1200C2FF" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-90,-80"/>

                <Grid Width="470" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <RotateTransform Angle="-4"/>
                    </Grid.RenderTransform>

                    <Border CornerRadius="38"
                            Margin="28,34,0,0"
                            Background="#33020617"
                            BorderBrush="#26FFFFFF"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="38" ShadowDepth="20" Opacity="0.28" Color="#FF020617"/>
                        </Border.Effect>
                    </Border>

                    <Border CornerRadius="38"
                            Background="#14FFFFFF"
                            BorderBrush="#38FFFFFF"
                            BorderThickness="1.5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.26" Color="#FF020617"/>
                        </Border.Effect>
                        <Grid>
                            <Border Margin="16"
                                    CornerRadius="30"
                                    BorderBrush="#44FFFFFF"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="True">
                                <Grid>
                                    <Image Source="pack://application:,,,/img/wallpapers/Login.png"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                         Margin="-220,0,0,0"/>
                                    <Border Height="110" VerticalAlignment="Top" CornerRadius="30,30,120,120" IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#7FFFFFFF" Offset="0"/>
                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Width="150"
                                    Height="18"
                                    CornerRadius="999"
                                    Background="#1F0F172A"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,18"
                                    IsHitTestVisible="False">
                                <Border.Effect>
                                    <BlurEffect Radius="12"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- LADO DIREITO - FORMULÁRIO -->
        <Border Grid.Column="1" Background="White" Padding="60,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <!-- Logo/Título -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/img/tesseractICO.png" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="obsseract" FontSize="28" FontWeight="ExtraBold" Foreground="#0078D4" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Observatório de Projetos Integradores" FontSize="14" Foreground="#999999" Margin="0,0,0,32"/>

                    <!-- Tabs -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Button x:Name="LoginTabButton" Content="Login" Style="{StaticResource TabButtonStyle}" Click="SwitchTab_Click" Tag="Login" Foreground="#0078D4" FontWeight="ExtraBold"/>
                        <Button x:Name="SignupTabButton" Content="Cadastro" Style="{StaticResource TabButtonStyle}" Click="SwitchTab_Click" Tag="Signup"/>
                    </StackPanel>

                    <!-- Linha divisória -->
                    <Rectangle Height="2" Fill="#FFE0E0E0" Margin="0,0,0,24"/>

                    <!-- LOGIN CONTENT -->
                    <StackPanel x:Name="LoginContent" Orientation="Vertical">
                        <TextBlock Text="Email ou Telefone" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="LoginEmail" Style="{StaticResource LoginInputStyle}" mah:TextBoxHelper.Watermark="seu@email.com"/>

                        <TextBlock Text="Senha" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <PasswordBox x:Name="LoginPassword" Style="{StaticResource LoginPasswordStyle}"/>

                        <TextBlock Text="Manter conectado" FontSize="12" Foreground="#666666" Margin="0,12,0,0"/>
                        <CheckBox Background="Transparent" Foreground="#0078D4" Margin="0,8,0,0" IsChecked="True"/>

                        <Button Content="Entrar" Style="{StaticResource PrimaryButtonStyle}" Click="LoginButton_Click" Foreground="White"/>

                        <TextBlock Text="Esqueceu a senha?" FontSize="12" Foreground="#0078D4" Margin="0,16,0,0" Cursor="Hand" TextDecorations="Underline" MouseLeftButtonUp="ForgotPasswordLink_MouseLeftButtonUp"/>
                    </StackPanel>

                    <!-- SIGNUP CONTENT -->
                    <StackPanel x:Name="SignupContent" Orientation="Vertical" Visibility="Collapsed">
                        <TextBlock Text="Nome Completo" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="SignupName" Style="{StaticResource LoginInputStyle}" mah:TextBoxHelper.Watermark="Seu Nome"/>

                        <TextBlock Text="Email" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <TextBox x:Name="SignupEmail" Style="{StaticResource LoginInputStyle}" mah:TextBoxHelper.Watermark="seu@email.com"/>

                        <TextBlock Text="Telefone" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <TextBox x:Name="SignupPhone" Style="{StaticResource LoginInputStyle}" mah:TextBoxHelper.Watermark="(XX) 9XXXX-XXXX"/>

                        <TextBlock Text="Curso" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <TextBox x:Name="SignupCourse" Style="{StaticResource LoginInputStyle}" mah:TextBoxHelper.Watermark="Engenharia de Software"/>

                        <TextBlock Text="Matrícula" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <TextBox x:Name="SignupRegistration" Style="{StaticResource LoginInputStyle}" mah:TextBoxHelper.Watermark="202400123"/>

                        <TextBlock Text="Senha" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <PasswordBox x:Name="SignupPassword" Style="{StaticResource LoginPasswordStyle}"/>
                        <TextBlock Text="Confirmar Senha" FontSize="13" Foreground="#333333" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <PasswordBox x:Name="SignupPasswordConfirm" Style="{StaticResource LoginPasswordStyle}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <CheckBox Background="Transparent" Foreground="#0078D4"/>
                            <TextBlock Text="Concordo com os Termos de Serviço" FontSize="12" Foreground="#666666" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Content="Criar Conta" Style="{StaticResource PrimaryButtonStyle}" Click="SignupButton_Click" Foreground="White"/>
                    </StackPanel>

                    <!-- Footer -->
                    <TextBlock Margin="0,32,0,0">
                        <Run Text="© 2026 MyApp. Todos os direitos reservados. " FontSize="11" Foreground="#999999"/>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</mah:MetroWindow>
