rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function requesterProfile() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function requesterRole() {
      return requesterProfile() == null
        ? ''
        : requesterProfile().get('role', '');
    }

    function requesterIsProfessorLike() {
      let role = requesterRole();
      return role == 'professor'
        || role == 'teacher'
        || role == 'advisor'
        || role == 'orientador';
    }

    function requesterIsCoordinatorLike() {
      let role = requesterRole();
      return role == 'coordinator'
        || role == 'course-coordinator'
        || role == 'academic-coordinator'
        || role == 'coordenador';
    }

    function requesterHasProfessorDiscovery() {
      return requesterIsProfessorLike() || requesterIsCoordinatorLike();
    }

    function isParticipantById(conversationId) {
      return signedIn()
        && conversationId.matches(
          '(^' + request.auth.uid + '-.*$)|(^.*-' + request.auth.uid + '$)'
        );
    }

    function isParticipantByData(data) {
      return signedIn() && (
        data.userAId == request.auth.uid ||
        data.userBId == request.auth.uid ||
        (data.participants is list && request.auth.uid in data.participants)
      );
    }

    function hasOptionalTimestamp(data, fieldName) {
      return !(fieldName in data) || data[fieldName] is timestamp;
    }

    function hasOptionalString(data, fieldName) {
      return !(fieldName in data) || data[fieldName] is string;
    }

    function hasOptionalBool(data, fieldName) {
      return !(fieldName in data) || data[fieldName] is bool;
    }

    function messageTypeOf(data) {
      return data.get('messageType', 'text');
    }

    function messageStickerAssetOf(data) {
      return data.get('stickerAsset', '');
    }

    function messageIsEdited(data) {
      return data.get('isEdited', false) == true;
    }

    function messageIsDeleted(data) {
      return data.get('isDeleted', false) == true || messageTypeOf(data) == 'deleted';
    }

    function validPermissionScope(scope) {
      return scope == 'team'
        || scope == 'course'
        || scope == 'leadership'
        || scope == 'private';
    }

    function validConversationMessageCreate(data, messageId) {
      return data.messageId is string
        && data.messageId == messageId
        && data.senderId is string
        && data.senderId == request.auth.uid
        && data.senderName is string
        && data.recipientId is string
        && data.content is string
        && data.messageType is string
        && data.stickerAsset is string
        && data.isEdited is bool
        && data.isEdited == false
        && data.isDeleted is bool
        && data.isDeleted == false
        && data.timestamp is timestamp
        && data.createdAt is timestamp
        && hasOptionalTimestamp(data, 'editedAt')
        && hasOptionalTimestamp(data, 'deletedAt');
    }

    function canMutateOwnMessage(oldData) {
      return oldData.senderId is string
        && oldData.senderId == request.auth.uid;
    }

    function validConversationMessageEdit(newData, oldData) {
      return newData.diff(oldData).affectedKeys().hasOnly([
          'content',
          'isEdited',
          'editedAt'
        ])
        && messageTypeOf(oldData) == 'text'
        && !messageIsDeleted(oldData)
        && newData.content is string
        && newData.content.size() > 0
        && messageStickerAssetOf(newData) == messageStickerAssetOf(oldData)
        && messageIsEdited(newData)
        && newData.editedAt is timestamp
        && !messageIsDeleted(newData)
        && !('deletedAt' in newData);
    }

    function validConversationMessageSoftDelete(newData, oldData) {
      return newData.diff(oldData).affectedKeys().hasOnly([
          'content',
          'messageType',
          'stickerAsset',
          'isDeleted',
          'deletedAt'
        ])
        && !messageIsDeleted(oldData)
        && newData.content is string
        && newData.messageType == 'deleted'
        && newData.stickerAsset is string
        && newData.stickerAsset == ''
        && messageIsDeleted(newData)
        && newData.deletedAt is timestamp
        && messageIsEdited(newData) == messageIsEdited(oldData)
        && newData.get('editedAt', null) == oldData.get('editedAt', null);
    }

    function isTeamCreatorData(data) {
      return signedIn() && data.createdBy == request.auth.uid;
    }

    function isTeamLeader(data) {
      return signedIn()
        && (data.leaderIds is list && request.auth.uid in data.leaderIds);
    }

    function isTeamProfessor(data) {
      return signedIn()
        && (data.professorIds is list && request.auth.uid in data.professorIds);
    }

    function isTeamCoordinator(data) {
      return signedIn()
        && (data.coordinatorIds is list && request.auth.uid in data.coordinatorIds);
    }

    function teamRoleOf(data) {
      return !signedIn()
        ? ''
        : isTeamProfessor(data)
          ? 'professor'
          : isTeamCoordinator(data)
            ? 'coordinator'
            : isTeamLeader(data)
              ? 'leader'
              : ((data.memberIds is list && request.auth.uid in data.memberIds) ? 'student' : '');
    }

    function canAddTeamMembers(data) {
      return isTeamCreatorData(data)
        || isTeamLeader(data)
        || isTeamProfessor(data)
        || isTeamCoordinator(data);
    }

    function canManageTeamMembership(data) {
      return isTeamProfessor(data) || isTeamCoordinator(data);
    }

    function teamVisible(data) {
      return signedIn() && (
        data.createdBy == request.auth.uid ||
        (data.memberIds is list && request.auth.uid in data.memberIds) ||
        teamRoleOf(data) != '' ||
        requesterHasProfessorDiscovery()
      );
    }

    function canUpdateTeamStructure(data) {
      return isTeamCreatorData(data)
        || isTeamLeader(data)
        || isTeamProfessor(data)
        || isTeamCoordinator(data)
        || requesterHasProfessorDiscovery();
    }

    function canReviewTeamDeliverables(data) {
      return isTeamLeader(data)
        || isTeamProfessor(data)
        || isTeamCoordinator(data)
        || requesterHasProfessorDiscovery();
    }

    function validExecutionRole(role) {
      return role == 'student' || role == 'leader';
    }

    function validTeamRole(role) {
      return role == 'student'
        || role == 'leader'
        || role == 'professor'
        || role == 'coordinator';
    }

    function studentSafeTeamUpdate(newData, oldData) {
      return newData.diff(oldData).affectedKeys().hasOnly([
        'assets',
        'notifications',
        'chatMessages',
        'updatedAt',
        'lastRealtimeSyncAt'
      ]);
    }

    function teamGovernanceKeys() {
      return [
        'members',
        'memberIds',
        'memberRolesByUserId',
        'leaderIds',
        'professorIds',
        'coordinatorIds',
        'studentIds',
        'focalProfessorUserId',
        'focalProfessorName',
        'professorSupervisorUserIds',
        'professorSupervisorNames'
      ];
    }

    function teamMembershipUpdateKeys() {
      return [
        'members',
        'memberIds',
        'memberRolesByUserId',
        'leaderIds',
        'professorIds',
        'coordinatorIds',
        'studentIds',
        'notifications',
        'updatedAt',
        'lastRealtimeSyncAt'
      ];
    }

    function professorFocusUpdateKeys() {
      return [
        'focalProfessorUserId',
        'focalProfessorName',
        'professorSupervisorUserIds',
        'professorSupervisorNames',
        'members',
        'memberIds',
        'memberRolesByUserId',
        'leaderIds',
        'professorIds',
        'coordinatorIds',
        'studentIds',
        'notifications',
        'updatedAt',
        'lastRealtimeSyncAt'
      ];
    }

    function canAppendTeamMembersUpdate(oldData, newData) {
      return canAddTeamMembers(oldData)
        && newData.diff(oldData).affectedKeys().hasOnly(teamMembershipUpdateKeys())
        && oldData.memberIds is list
        && newData.memberIds is list
        && newData.memberIds.hasAll(oldData.memberIds)
        && newData.memberIds.size() >= oldData.memberIds.size()
        && oldData.studentIds is list
        && newData.studentIds is list
        && newData.studentIds.hasAll(oldData.studentIds)
        && newData.studentIds.size() == oldData.studentIds.size() + (newData.memberIds.size() - oldData.memberIds.size())
        && newData.leaderIds == oldData.leaderIds
        && newData.professorIds == oldData.professorIds
        && newData.coordinatorIds == oldData.coordinatorIds
        && newData.memberRolesByUserId.diff(oldData.memberRolesByUserId).changedKeys().size() == 0
        && newData.memberRolesByUserId.diff(oldData.memberRolesByUserId).removedKeys().size() == 0;
    }

    function canManageTeamMembershipUpdate(oldData, newData) {
      return canManageTeamMembership(oldData)
        && newData.diff(oldData).affectedKeys().hasOnly(teamMembershipUpdateKeys());
    }

    function canClaimProfessorFocusUpdate(oldData, newData) {
      return requesterIsProfessorLike()
        && teamVisible(oldData)
        && newData.diff(oldData).affectedKeys().hasOnly(professorFocusUpdateKeys())
        && newData.focalProfessorUserId == request.auth.uid
        && newData.focalProfessorName is string
        && newData.professorIds is list
        && request.auth.uid in newData.professorIds
        && newData.memberIds is list
        && request.auth.uid in newData.memberIds;
    }

    function canEditTeamStructureUpdate(oldData, newData) {
      return canUpdateTeamStructure(oldData)
        && !newData.diff(oldData).affectedKeys().hasAny(teamGovernanceKeys());
    }

    function canDeleteTeamDocument(data) {
      return isTeamCreatorData(data);
    }

    function canViewScopedTeamAsset(data, permissionScope, ownerUserId) {
      return teamVisible(data)
        && (
          !validPermissionScope(permissionScope) ||
          permissionScope == 'team' ||
          permissionScope == 'course' ||
          isTeamLeader(data) ||
          isTeamProfessor(data) ||
          isTeamCoordinator(data) ||
          (permissionScope == 'private' && ownerUserId == request.auth.uid)
        );
    }

    function validTeamRoleIndexes(data) {
      return data.memberRolesByUserId is map
        && data.leaderIds is list
        && data.professorIds is list
        && data.coordinatorIds is list
        && data.studentIds is list;
    }

    function validTeamPayload(data) {
      return data.teamId is string
        && data.teamName is string
        && data.course is string
        && data.className is string
        && data.classId is string
        && data.academicTerm is string
        && data.templateId is string
        && data.templateName is string
        && data.createdBy is string
        && data.isActive is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.lastRealtimeSyncAt == null || data.lastRealtimeSyncAt is timestamp)
        && data.projectProgress is int
        && data.projectProgress >= 0
        && data.projectProgress <= 100
        && (data.projectDeadline == null || data.projectDeadline is timestamp)
        && data.projectStatus is string
        && data.teacherNotes is string
        && data.focalProfessorUserId is string
        && data.focalProfessorName is string
        && data.professorSupervisorUserIds is list
        && data.professorSupervisorNames is list
        && data.defaultFilePermissionScope is string
        && validPermissionScope(data.defaultFilePermissionScope)
        && data.ucs is list
        && data.memberIds is list
        && (request.auth.uid in data.memberIds || requesterHasProfessorDiscovery())
        && data.members is list
        && validTeamRoleIndexes(data)
        && data.semesterTimeline is list
        && data.accessRules is list
        && data.milestones is list
        && data.assets is list
        && data.taskColumns is list
        && data.notifications is list
        && data.chatMessages is list
        && data.csdBoard is map;
    }

    function validUserTeamPayload(data, userId) {
      return data.userId == userId
        && data.teamId is string
        && data.teamName is string
        && data.addedAt is timestamp;
    }

    function validTeachingClassPayload(data, classId) {
      return data.classId is string
        && data.classId == classId
        && data.className is string
        && data.course is string
        && data.academicTerm is string
        && data.description is string
        && data.joinCode is string
        && data.createdBy is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.professorUserIds is list
        && data.professorNames is list
        && data.studentIds is list
        && data.studentSummaries is list;
    }

    function teachingClassDocument(classId) {
      return get(/databases/$(database)/documents/teachingClasses/$(classId));
    }

    function teachingClassExists(classId) {
      return teachingClassDocument(classId).data != null;
    }

    function teachingClassVisible(data) {
      return signedIn() && (
        data.createdBy == request.auth.uid ||
        (data.professorUserIds is list && request.auth.uid in data.professorUserIds) ||
        (data.studentIds is list && request.auth.uid in data.studentIds) ||
        requesterHasProfessorDiscovery()
      );
    }

    function canManageTeachingClass(data) {
      return signedIn() && (
        data.createdBy == request.auth.uid ||
        (data.professorUserIds is list && request.auth.uid in data.professorUserIds) ||
        requesterIsCoordinatorLike()
      );
    }

    function canSelfJoinTeachingClass(oldData, newData) {
      return signedIn()
        && newData.diff(oldData).affectedKeys().hasOnly([
          'studentIds',
          'studentSummaries',
          'updatedAt'
        ])
        && oldData.studentIds is list
        && newData.studentIds is list
        && !(request.auth.uid in oldData.studentIds)
        && request.auth.uid in newData.studentIds
        && newData.studentIds.hasAll(oldData.studentIds)
        && newData.professorUserIds == oldData.professorUserIds
        && newData.professorNames == oldData.professorNames
        && newData.className == oldData.className
        && newData.course == oldData.course
        && newData.academicTerm == oldData.academicTerm
        && newData.description == oldData.description
        && newData.joinCode == oldData.joinCode
        && newData.createdBy == oldData.createdBy
        && newData.createdAt == oldData.createdAt;
    }

    function canWriteUserClassEnrollment(data) {
      return signedIn()
        && data.userId is string
        && data.classId is string
        && data.className is string
        && data.role is string
        && validTeamRole(data.role)
        && data.joinedAt is timestamp
        && (
          data.userId == request.auth.uid ||
          (teachingClassExists(data.classId)
            && canManageTeachingClass(teachingClassDocument(data.classId).data))
        );
    }

    function teamDocument(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId));
    }

    function teamExists(teamId) {
      return teamDocument(teamId).data != null;
    }

    function isTeamCreator(teamId) {
      return signedIn()
        && teamExists(teamId)
        && teamDocument(teamId).data.createdBy == request.auth.uid;
    }

    function canWriteUserTeamReference(data) {
      return signedIn()
        && data.userId is string
        && data.teamId is string
        && data.teamName is string
        && data.addedAt is timestamp
        && (
          data.userId == request.auth.uid ||
          (teamExists(data.teamId) && (
            canAddTeamMembers(teamDocument(data.teamId).data) ||
            canManageTeamMembership(teamDocument(data.teamId).data)
          ))
        );
    }

    function validTeamAssetFilePayload(data) {
      return data.teamId is string
        && data.assetId is string
        && data.versionNumber is int
        && data.versionNumber > 0
        && data.fileName is string
        && data.mimeType is string
        && data.permissionScope is string
        && validPermissionScope(data.permissionScope)
        && data.storageKind is string
        && data.sizeBytes is int
        && data.sizeBytes >= 0
        && data.uploadedByUserId is string
        && data.uploadedByUserId == request.auth.uid
        && data.uploadedAt is timestamp
        && data.contentBase64 is string
        && data.contentBase64.size() < 900000;
    }

    function canWriteTeamAssetFile(data) {
      return signedIn()
        && teamExists(data.teamId)
        && teamVisible(teamDocument(data.teamId).data);
    }

    function canReadTeamAssetFile(data) {
      return signedIn()
        && teamExists(data.teamId)
        && canViewScopedTeamAsset(
          teamDocument(data.teamId).data,
          data.permissionScope,
          data.uploadedByUserId
        );
    }

    function validTaskCardPayload(data, teamId, cardId) {
      return data.teamId is string
        && data.teamId == teamId
        && data.id is string
        && data.id == cardId
        && data.columnId is string
        && data.title is string
        && data.description is string
        && data.priority is string
        && (data.dueDate == null || data.dueDate is timestamp)
        && data.estimatedHours is int
        && data.estimatedHours >= 0
        && data.workloadPoints is int
        && data.workloadPoints >= 0
        && data.requiredRole is string
        && validExecutionRole(data.requiredRole)
        && data.requiresProfessorReview is bool
        && data.assignedUserIds is list
        && data.mentionedUserIds is list
        && data.comments is list
        && data.attachments is list
        && data.createdAt is timestamp
        && data.createdByUserId is string
        && data.updatedAt is timestamp
        && data.updatedByUserId is string;
    }

    function validMilestonePayload(data, teamId, milestoneId) {
      return data.teamId is string
        && data.teamId == teamId
        && data.id is string
        && data.id == milestoneId
        && data.title is string
        && data.notes is string
        && data.status is string
        && (data.dueDate == null || data.dueDate is timestamp)
        && data.createdByUserId is string
        && data.ownerUserId is string
        && data.requiresProfessorReview is bool
        && data.mentionedUserIds is list
        && data.comments is list
        && data.attachments is list
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.updatedByUserId is string;
    }

    function taskCardCollaborativeUpdate(newData, oldData) {
      return newData.diff(oldData).affectedKeys().hasOnly([
          'comments',
          'attachments',
          'mentionedUserIds',
          'updatedAt',
          'updatedByUserId'
        ])
        && newData.updatedByUserId == request.auth.uid;
    }

    function milestoneCollaborativeUpdate(newData, oldData) {
      return newData.diff(oldData).affectedKeys().hasOnly([
          'comments',
          'attachments',
          'mentionedUserIds',
          'updatedAt',
          'updatedByUserId'
        ])
        && newData.updatedByUserId == request.auth.uid;
    }

    function milestoneReviewUpdate(newData, oldData) {
      return newData.diff(oldData).affectedKeys().hasOnly([
          'status',
          'updatedAt',
          'updatedByUserId'
        ])
        && newData.updatedByUserId == request.auth.uid;
    }

    function connectionVisible(data) {
      return signedIn() && (
        data.userAId == request.auth.uid ||
        data.userBId == request.auth.uid ||
        (data.userIds is list && request.auth.uid in data.userIds)
      );
    }

    function connectionDocument(connectionId) {
      return get(/databases/$(database)/documents/connections/$(connectionId));
    }

    function connectionExists(connectionId) {
      return connectionDocument(connectionId).data != null;
    }

    function isConnectionParticipant(connectionId) {
      return signedIn()
        && connectionExists(connectionId)
        && request.auth.uid in connectionDocument(connectionId).data.userIds;
    }

    function validConnectionPayload(data, connectionId) {
      return data.connectionId is string
        && data.connectionId == connectionId
        && data.userAId is string
        && data.userBId is string
        && data.userAId != data.userBId
        && data.userIds is list
        && data.userIds.size() == 2
        && data.userAId in data.userIds
        && data.userBId in data.userIds
        && request.auth.uid in data.userIds
        && data.requestedBy is string
        && data.respondedBy is string
        && data.status is string
        && (data.status == 'pending' || data.status == 'active' || data.status == 'declined')
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function canWriteUserConnectionReference(data) {
      return signedIn()
        && data.userId is string
        && data.connectionId is string
        && data.connectedUserId is string
        && data.connectedUserName is string
        && data.connectedUserEmail is string
        && data.requestedBy is string
        && data.status is string
        && data.notificationType is string
        && data.notificationMessage is string
        && data.isRead is bool
        && data.addedAt is timestamp
        && data.updatedAt is timestamp
        && (
          data.userId == request.auth.uid ||
          isConnectionParticipant(data.connectionId)
        );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
    }

    match /conversations/{conversationId} {
      allow get: if isParticipantByData(resource.data);
      allow list: if signedIn();

      allow create: if isParticipantById(conversationId)
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.userAId is string
        && request.resource.data.userBId is string
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessageTime is timestamp
        && request.resource.data.lastSenderId is string;

      allow update: if isParticipantByData(resource.data)
        && isParticipantByData(request.resource.data);

      allow delete: if false;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isParticipantById(conversationId);

      allow create: if isParticipantById(conversationId)
        && validConversationMessageCreate(request.resource.data, messageId);

      allow update: if isParticipantById(conversationId)
        && canMutateOwnMessage(resource.data)
        && (
          validConversationMessageEdit(request.resource.data, resource.data) ||
          validConversationMessageSoftDelete(request.resource.data, resource.data)
        );

      allow delete: if false;
    }

    match /teams/{teamId} {
      allow get: if teamVisible(resource.data);
      allow list: if signedIn();

      allow create: if signedIn()
        && validTeamPayload(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.teamId == teamId;

      allow update: if teamVisible(resource.data)
        && validTeamPayload(request.resource.data)
        && request.resource.data.teamId == teamId
        && request.resource.data.createdBy == resource.data.createdBy
        && (
          canClaimProfessorFocusUpdate(resource.data, request.resource.data) ||
          canManageTeamMembershipUpdate(resource.data, request.resource.data) ||
          canAppendTeamMembersUpdate(resource.data, request.resource.data) ||
          canEditTeamStructureUpdate(resource.data, request.resource.data) ||
          studentSafeTeamUpdate(request.resource.data, resource.data)
        );

      allow delete: if canDeleteTeamDocument(resource.data);
    }

    match /teams/{teamId}/taskCards/{cardId} {
      allow get: if teamExists(teamId)
        && teamVisible(teamDocument(teamId).data);
      allow list: if false;

      allow create: if teamExists(teamId)
        && validTaskCardPayload(request.resource.data, teamId, cardId)
        && canUpdateTeamStructure(teamDocument(teamId).data)
        && request.resource.data.updatedByUserId == request.auth.uid;

      allow update: if teamExists(teamId)
        && validTaskCardPayload(request.resource.data, teamId, cardId)
        && (
          request.resource.data == resource.data ||
          (canUpdateTeamStructure(teamDocument(teamId).data)
            && request.resource.data.updatedByUserId == request.auth.uid) ||
          (teamVisible(teamDocument(teamId).data)
            && taskCardCollaborativeUpdate(request.resource.data, resource.data))
        );

      allow delete: if teamExists(teamId)
        && canUpdateTeamStructure(teamDocument(teamId).data);
    }

    match /teams/{teamId}/milestones/{milestoneId} {
      allow get: if teamExists(teamId)
        && teamVisible(teamDocument(teamId).data);
      allow list: if false;

      allow create: if teamExists(teamId)
        && validMilestonePayload(request.resource.data, teamId, milestoneId)
        && canUpdateTeamStructure(teamDocument(teamId).data)
        && request.resource.data.updatedByUserId == request.auth.uid;

      allow update: if teamExists(teamId)
        && validMilestonePayload(request.resource.data, teamId, milestoneId)
        && (
          request.resource.data == resource.data ||
          (canUpdateTeamStructure(teamDocument(teamId).data)
            && request.resource.data.updatedByUserId == request.auth.uid) ||
          (canReviewTeamDeliverables(teamDocument(teamId).data)
            && milestoneReviewUpdate(request.resource.data, resource.data)) ||
          (teamVisible(teamDocument(teamId).data)
            && milestoneCollaborativeUpdate(request.resource.data, resource.data))
        );

      allow delete: if teamExists(teamId)
        && canUpdateTeamStructure(teamDocument(teamId).data);
    }

    match /teachingClasses/{classId} {
      allow get: if teachingClassVisible(resource.data);
      allow list: if signedIn();

      allow create: if signedIn()
        && requesterHasProfessorDiscovery()
        && validTeachingClassPayload(request.resource.data, classId)
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.professorUserIds;

      allow update: if teachingClassVisible(resource.data)
        && validTeachingClassPayload(request.resource.data, classId)
        && request.resource.data.createdBy == resource.data.createdBy
        && (
          canManageTeachingClass(resource.data) ||
          canSelfJoinTeachingClass(resource.data, request.resource.data)
        );

      allow delete: if canManageTeachingClass(resource.data);
    }

    match /teamAssetFiles/{documentId} {
      allow get: if canReadTeamAssetFile(resource.data);
      allow list: if false;

      allow create: if validTeamAssetFilePayload(request.resource.data)
        && canWriteTeamAssetFile(request.resource.data);

      allow update: if false;

      allow delete: if canReadTeamAssetFile(resource.data)
        && (
          resource.data.uploadedByUserId == request.auth.uid ||
          canManageTeamMembership(teamDocument(resource.data.teamId).data)
        );
    }

    match /connections/{connectionId} {
      allow get: if connectionVisible(resource.data);
      allow list: if signedIn();

      allow create: if signedIn()
        && validConnectionPayload(request.resource.data, connectionId)
        && request.resource.data.requestedBy == request.auth.uid;

      allow update: if connectionVisible(resource.data)
        && validConnectionPayload(request.resource.data, connectionId)
        && request.resource.data.userAId == resource.data.userAId
        && request.resource.data.userBId == resource.data.userBId
        && request.resource.data.requestedBy == resource.data.requestedBy;

      allow delete: if false;
    }

    match /userConnections/{documentId} {
      allow get: if signedIn() && resource.data.userId == request.auth.uid;
      allow list: if signedIn();

      allow create, update: if canWriteUserConnectionReference(request.resource.data);

      allow delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid ||
          isConnectionParticipant(resource.data.connectionId)
        );
    }

    match /userTeams/{documentId} {
      allow get: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        requesterHasProfessorDiscovery()
      );
      allow list: if signedIn();

      allow create, update: if canWriteUserTeamReference(request.resource.data);

      allow delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid ||
          (teamExists(resource.data.teamId) && canManageTeamMembership(teamDocument(resource.data.teamId).data))
        );
    }

    match /userClassEnrollments/{documentId} {
      allow get: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        (teachingClassExists(resource.data.classId)
          && teachingClassVisible(teachingClassDocument(resource.data.classId).data))
      );
      allow list: if signedIn();

      allow create, update: if canWriteUserClassEnrollment(request.resource.data);

      allow delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid ||
          (teachingClassExists(resource.data.classId)
            && canManageTeachingClass(teachingClassDocument(resource.data.classId).data))
        );
    }
  }
}