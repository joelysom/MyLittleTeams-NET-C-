rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function requesterProfile() {
      return signedIn()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function requesterRole() {
      return requesterProfile() == null
        ? ''
        : requesterProfile().role;
    }

    function requesterIsProfessorLike() {
      let role = requesterRole();
      return role == 'professor'
        || role == 'teacher'
        || role == 'advisor'
        || role == 'orientador';
    }

    function requesterIsCoordinatorLike() {
      let role = requesterRole();
      return role == 'coordinator'
        || role == 'course-coordinator'
        || role == 'academic-coordinator'
        || role == 'coordenador';
    }

    function requesterHasProfessorDiscovery() {
      return requesterIsProfessorLike() || requesterIsCoordinatorLike();
    }

    function validPermissionScope(scope) {
      return scope == 'team'
        || scope == 'course'
        || scope == 'leadership'
        || scope == 'private';
    }

    function validTeachingClassPermissionScope(scope) {
      return scope == 'class'
        || scope == 'course'
        || scope == 'staff'
        || scope == 'private';
    }

    function teachingClassDocument(classId) {
      return firestore.get(/databases/(default)/documents/teachingClasses/$(classId));
    }

    function teachingClassExists(classId) {
      return teachingClassDocument(classId).data != null;
    }

    function teachingClassVisible(data) {
      return signedIn() && (
        data.createdBy == request.auth.uid ||
        (data.professorUserIds is list && request.auth.uid in data.professorUserIds) ||
        (data.studentIds is list && request.auth.uid in data.studentIds)
      );
    }

    function canManageTeachingClass(data) {
      return signedIn() && (
        data.createdBy == request.auth.uid ||
        (data.professorUserIds is list && request.auth.uid in data.professorUserIds)
      );
    }

    function teamDocument(teamId) {
      return firestore.get(/databases/(default)/documents/teams/$(teamId));
    }

    function teamExists(teamId) {
      return teamDocument(teamId).data != null;
    }

    function isTeamLeader(data) {
      return signedIn()
        && (data.leaderIds is list && request.auth.uid in data.leaderIds);
    }

    function isTeamProfessor(data) {
      return signedIn()
        && (data.professorIds is list && request.auth.uid in data.professorIds);
    }

    function isTeamCoordinator(data) {
      return signedIn()
        && (data.coordinatorIds is list && request.auth.uid in data.coordinatorIds);
    }

    function teamVisible(data) {
      return signedIn() && (
        data.createdBy == request.auth.uid ||
        (data.memberIds is list && request.auth.uid in data.memberIds) ||
        isTeamLeader(data) ||
        isTeamProfessor(data) ||
        isTeamCoordinator(data) ||
        requesterHasProfessorDiscovery()
      );
    }

    function canViewScopedTeamAsset(data, permissionScope, ownerUserId) {
      return teamVisible(data)
        && (
          !validPermissionScope(permissionScope) ||
          permissionScope == 'team' ||
          permissionScope == 'course' ||
          isTeamLeader(data) ||
          isTeamProfessor(data) ||
          isTeamCoordinator(data) ||
          (permissionScope == 'private' && ownerUserId == request.auth.uid)
        );
    }

    function canWriteTeamAsset(data, ownerUserId, permissionScope) {
      return signedIn()
        && request.auth.uid == ownerUserId
        && validPermissionScope(permissionScope)
        && teamVisible(data);
    }

    function canDeleteTeamAsset(data, ownerUserId) {
      return signedIn()
        && (
          ownerUserId == request.auth.uid ||
          data.createdBy == request.auth.uid ||
          isTeamProfessor(data) ||
          isTeamCoordinator(data)
        );
    }

    function canViewScopedTeachingClassAsset(data, permissionScope, ownerUserId) {
      return teachingClassVisible(data)
        && validTeachingClassPermissionScope(permissionScope)
        && (
          permissionScope == 'class'
          || permissionScope == 'course'
          || canManageTeachingClass(data)
          || (permissionScope == 'private' && ownerUserId == request.auth.uid)
        );
    }

    function canWriteTeachingClassAsset(data, ownerUserId, permissionScope) {
      return signedIn()
        && request.auth.uid == ownerUserId
        && validTeachingClassPermissionScope(permissionScope)
        && (
          (permissionScope == 'private' && teachingClassVisible(data))
          || (permissionScope != 'private' && canManageTeachingClass(data))
        );
    }

    function canDeleteTeachingClassAsset(data, ownerUserId) {
      return signedIn()
        && (
          ownerUserId == request.auth.uid ||
          data.createdBy == request.auth.uid ||
          canManageTeachingClass(data)
        );
    }

    function validTeachingClassAssetPath(permissionScope, ownerUserId, assetId, versionId, fileName) {
      return validTeachingClassPermissionScope(permissionScope)
        && ownerUserId.size() > 0
        && assetId.size() > 0
        && versionId.matches('^v[0-9]{4}$')
        && fileName.size() > 0;
    }

    function validTeachingClassIconPath(ownerUserId, assetId, versionId, fileName) {
      return ownerUserId.size() > 0
        && assetId.size() > 0
        && versionId.matches('^v[0-9]{4}$')
        && fileName.size() > 0;
    }

    function isConversationParticipantById(conversationId) {
      return signedIn()
        && conversationId.matches(
          '(^' + request.auth.uid + '-.*$)|(^.*-' + request.auth.uid + '$)'
        );
    }

    function validChatAssetPath(ownerUserId, messageId, fileName) {
      return ownerUserId.size() > 0
        && messageId.size() > 0
        && fileName.size() > 0;
    }

    match /chat-assets/{conversationId}/{ownerUserId}/{messageId}/{fileName} {
      allow read: if validChatAssetPath(ownerUserId, messageId, fileName)
        && isConversationParticipantById(conversationId);

      allow write: if validChatAssetPath(ownerUserId, messageId, fileName)
        && signedIn()
        && request.auth.uid == ownerUserId
        && isConversationParticipantById(conversationId);

      allow delete: if validChatAssetPath(ownerUserId, messageId, fileName)
        && signedIn()
        && request.auth.uid == ownerUserId
        && isConversationParticipantById(conversationId);
    }

    match /team-assets/{teamId}/{permissionScope}/{ownerUserId}/{assetId}/{versionId}/{fileName} {
      allow read: if teamExists(teamId)
        && canViewScopedTeamAsset(teamDocument(teamId).data, permissionScope, ownerUserId);

      allow write: if teamExists(teamId)
        && canWriteTeamAsset(teamDocument(teamId).data, ownerUserId, permissionScope);

      allow delete: if teamExists(teamId)
        && canDeleteTeamAsset(teamDocument(teamId).data, ownerUserId);
    }

    match /teaching-class-assets/{classId}/{permissionScope}/{ownerUserId}/{assetId}/{versionId}/{fileName} {
      allow read: if validTeachingClassAssetPath(permissionScope, ownerUserId, assetId, versionId, fileName)
        && teachingClassExists(classId)
        && canViewScopedTeachingClassAsset(teachingClassDocument(classId).data, permissionScope, ownerUserId);

      allow write: if validTeachingClassAssetPath(permissionScope, ownerUserId, assetId, versionId, fileName)
        && teachingClassExists(classId)
        && canWriteTeachingClassAsset(teachingClassDocument(classId).data, ownerUserId, permissionScope);

      allow delete: if validTeachingClassAssetPath(permissionScope, ownerUserId, assetId, versionId, fileName)
        && teachingClassExists(classId)
        && canDeleteTeachingClassAsset(teachingClassDocument(classId).data, ownerUserId);
    }

    match /teaching-class-icons/{classId}/{ownerUserId}/{assetId}/{versionId}/{fileName} {
      allow read: if validTeachingClassIconPath(ownerUserId, assetId, versionId, fileName)
        && teachingClassExists(classId)
        && teachingClassVisible(teachingClassDocument(classId).data);

      allow write: if validTeachingClassIconPath(ownerUserId, assetId, versionId, fileName)
        && teachingClassExists(classId)
        && request.auth.uid == ownerUserId
        && canManageTeachingClass(teachingClassDocument(classId).data);

      allow delete: if validTeachingClassIconPath(ownerUserId, assetId, versionId, fileName)
        && teachingClassExists(classId)
        && canDeleteTeachingClassAsset(teachingClassDocument(classId).data, ownerUserId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}