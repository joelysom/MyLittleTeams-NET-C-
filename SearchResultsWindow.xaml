<mah:MetroWindow x:Class="MeuApp.SearchResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="Pesquisar Conexões" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="White"
        BorderThickness="0"
        ResizeMode="CanResize">

    <Grid Background="White">
        <StackPanel Orientation="Vertical" Margin="20">
            <!-- SEARCH HEADER -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,16">
                <TextBlock Text="🔍 Resultados da busca de conexões" FontSize="18" FontWeight="ExtraBold" Foreground="#FF333333" Margin="0,0,0,8"/>
                <TextBlock x:Name="SearchQueryText" Text="Buscando por: ..." FontSize="12" Foreground="#FF666666"/>
            </StackPanel>

            <!-- RESULTS LIST -->
            <Border Background="#FFF5F5F5" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="8" Padding="0">
                <ListBox x:Name="ResultsList" Background="Transparent" BorderThickness="0" ItemsSource="{Binding Results}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#FFE8E8E8" BorderThickness="0,0,0,1" Padding="16,12" Margin="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- USER INFO -->
                                    <StackPanel Grid.Column="0" Orientation="Vertical">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Ellipse Width="32" Height="32" Fill="#FF0078D4" VerticalAlignment="Top" Margin="0,0,12,0"/>
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#FF333333"/>
                                                <TextBlock Text="{Binding Email}" FontSize="11" Foreground="#FF999999" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="44,0,0,0">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Text="Matrícula" FontSize="10" Foreground="#FF999999"/>
                                                <TextBlock Text="{Binding Registration}" FontSize="11" FontWeight="SemiBold" Foreground="#FF333333"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Vertical" Margin="16,0,0,0">
                                                <TextBlock Text="Curso" FontSize="10" Foreground="#FF999999"/>
                                                <TextBlock Text="{Binding Course}" FontSize="11" FontWeight="SemiBold" Foreground="#FF333333"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ACTIONS -->
                                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                        <Button Content="Conversar" Background="#FF0078D4" Foreground="White" FontSize="11" Padding="10,6" BorderThickness="0" Cursor="Hand" Click="StartConversation_Click" Tag="{Binding UserId}" Margin="0,0,0,8"/>
                                        <Button Content="Detalhes" Background="#FFFFFFFF" Foreground="#FF0F172A" FontSize="11" Padding="10,6" BorderBrush="#FFCBD5E1" BorderThickness="1" Cursor="Hand" Click="ViewProfile_Click" Margin="0,0,0,8"/>
                                        <Button Content="{Binding ConnectionButtonLabel}" Background="#FFF8FAFC" Foreground="#FF0F172A" FontSize="11" Padding="10,6" BorderBrush="#FFCBD5E1" BorderThickness="1" Cursor="Hand" IsEnabled="{Binding CanCreateConnection}" Click="AddFriend_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- NO RESULTS MESSAGE -->
            <TextBlock x:Name="NoResultsText" Text="Nenhuma conexão encontrada" FontSize="13" Foreground="#FF999999" TextAlignment="Center" Margin="0,32" Visibility="Collapsed"/>

            <!-- LOADING MESSAGE -->
            <TextBlock x:Name="LoadingText" Text="Buscando..." FontSize="13" Foreground="#FF0078D4" TextAlignment="Center" Margin="0,32" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
